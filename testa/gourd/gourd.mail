{*************************** DEFINITION DES VARIABLES ************************}
DefVar pi, R, Rm, teta, eps, eps1, eps2, epaisseur, Nb_aretes, Hauteur_Cylindre,
       Hauteur_Cylindre1, Hauteur_Bouchon, Aretes_Plastique, Aretes_Air,
       Nb_aretes2, Nb_aretes3;
  pi=atan(1)*4;
  R=0.16/2;
  Rm=0.007*1;
  teta=pi/3;
  eps=0;
  eps1=0.001;
  eps2=0.002;
  epaisseur=0.06/2;
  Nb_aretes=2;    {goulot}
  Nb_aretes2=3;
  Nb_aretes3=3;    {cylindre}
  Hauteur_Cylindre1=0.035;
  Hauteur_Bouchon=0.02/2;
  Aretes_Plastique=1;
  Aretes_Air=1;

 Hauteur_Cylindre=Hauteur_Cylindre1+(R+eps)*sin(teta);

{******************************************************************************}
{******************************************************************************}
{********************** LA GOURDE SANS LE GOULOT **************************}
{******************************************************************************}
{******************************************************************************}

{************************* DEFINITION DES POINTS *****************************}
           1;
{ POINTS sommets de l objet }
           1;
{ FRAPPE des valeurs }
{ NOM DU POINT ou ABANDON?        }

Origine;
{ NOM DE TRANSFORMATION        }
I;
{ DANS LE LEXIQUE ~>TRANSFO }
           1;
{ coordonnees x y z }
{ VALEUR de X=?        }
0;
{ VALEUR de Y=?        }
0;
{ VALEUR de Z=?        }
0;
{ COORPO '3 coordonnees cartesiennes du point' xyz ; }
{ NOM DU POINT ou ABANDON?        }

Origine_z ;
{ NOM DE TRANSFORMATION        }
I;
{ DANS LE LEXIQUE ~>TRANSFO }
           1;
{ coordonnees x y z }
{ VALEUR de X=?        }
0;
{ VALEUR de Y=?        }
0;
{ VALEUR de Z=?        }
R*sin(teta) +eps;
{ COORPO '3 coordonnees cartesiennes du point' xyz ; }
{ NOM DU POINT ou ABANDON?        } 

a ; I; 1;
   0; R+eps; 0;

b ; I; 1;
   (1/2*epaisseur)*sin(pi/4); R+eps; 0;

c ; I; 1;
   epaisseur+eps; R+eps; 0;

d ; I; 1;
   epaisseur+eps; R-Rm; 0;

e ; I; 1;
   epaisseur+eps; (R-Rm)*cos(teta); 0;

f ; I; 1;
   epaisseur+eps; (1/2*epaisseur)*cos(pi/4); 0;

g ; I; 1;
   epaisseur+eps; 0; 0;

h ; I; 1;
   epaisseur+eps; 0; (R-Rm)*sin(teta);

i ; I; 1;
   epaisseur+eps; (1/2*epaisseur)*cos(pi/4); (R-Rm)*sin(teta);

j ; I; 1;
   epaisseur+eps; (R-Rm)*cos(teta); (R-Rm)*sin(teta);

k ; I; 1;
   epaisseur+eps; R*cos(teta); R*sin(teta)+eps;

l ; I; 1;
   epaisseur+eps; (1/2*epaisseur)*cos(pi/4); R*sin(teta)+eps;

m ; I; 1;
   epaisseur+eps; 0; R*sin(teta)+eps;

n ; I; 1;
   1/2*epaisseur; 0; R*sin(teta)+eps;

o ; I; 1;
   (1/2*epaisseur)*sin(pi/4); (1/2*epaisseur)*cos(pi/4); R*sin(teta)+eps;

p ; I; 1;
   0; 1/2*epaisseur; R*sin(teta)+eps;

q ; I; 1;
   0; R*cos(teta); R*sin(teta)+eps;

r ; I; 1;
   (1/2*epaisseur)*sin(pi/4); R*cos(teta); R*sin(teta)+eps;

{ pour maillage de l'eau }

s ; I; 1;
   (1/2*epaisseur)*sin(pi/4); R*cos(teta); 0;

t ; I; 1;
   0; R*cos(teta); 0;

u ; I; 1;
   1/2*epaisseur; 0; 0;

v ; I; 1;
   (1/2*epaisseur)*sin(pi/4); (1/2*epaisseur)*cos(pi/4); 0;

w ; I; 1;
   0; 1/2*epaisseur; 0;
   
x ; I; 1;
   (1/2*epaisseur)*sin(pi/4); 0; 0;

@;


{**************************** DEFINITION DES LIGNES **************************}
           2;
{ LIGNES aretes de l objet }
{ NOM DE LA LIGNE ou ABANDON?        }

a_b ; I; 2;
   Nb_aretes; 1;
   a ; b ;

b_d ; I; 28; { ligne avec conge }
   Nb_aretes2; 0.0045;
   b ; c ; d ;

d_e ; I; 2;
   Nb_aretes2; 1;
   d ; e ;

e_f ; I; 2;
   Nb_aretes2; 1;
   e ; f ;

f_g ; I; 2;
   Nb_aretes; 1;
   f ; g ;

g_h ; I; 2;
   Nb_aretes2; 1;
   g ; h ;

h_i ; I; 2;
   Nb_aretes; 1;
   h ; i ;

i_j ; I; 2;
   Nb_aretes2; 1;
   i ; j ;

q_r ; I; 2;
   Nb_aretes; 1;
   q ; r ;

p_q ; I; 2;
   Nb_aretes2; 1;
   p ; q ;

o_r ; I; 2;
   Nb_aretes2; 1;
   o ; r ;

j_r ; I; 28; { ligne avec conge }
   Nb_aretes2; 0.0045;
   r ; k ; j ;

i_o ; I; 28; { ligne avec conge }
   Nb_aretes2; 0.0045;
   o ; l ; i ;

h_n ; I; 28; { ligne avec conge }
   Nb_aretes2; 0.0045;
   n ; m ; h ;

o_p ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes; 1;
   o ; p ;
   Origine_z ;
   1/2*epaisseur;

n_o ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes; 1;
   n ; o ;
   Origine_z ;
   1/2*epaisseur;

d_j ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes2; 1;
   d ; j ;
   g ;
   R-Rm;

a_q ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes2; 1;
   a ; q ;
   Origine;
   R;

e_j ; I; 2;
   Nb_aretes2; 1;
   e ; j ;

f_i ; I; 2;
   Nb_aretes2; 1;
   f ; i ;

{ pour maillage de l'eau }

e_s ; I; 2;
   Nb_aretes2; 1;
   e ; s ;

s_t ; I; 2;
   Nb_aretes; 1;
   s ; t ;

e_t ; I; 51; 2; { union de plusieurs lignes }
   e_s ; s_t ;

r_s ; I; 2;
   Nb_aretes2; 1;
   r ; s ;

q_t ; I; 2;
   Nb_aretes2; 1;
   q ; t ;

s_v ; I; 2;
   Nb_aretes2; 1;
   s ; v ;

t_w ; I; 2;
   Nb_aretes2; 1;
   t ; w ;

p_w ; I; 2;
   Nb_aretes2; 1;
   p ; w ;

o_v ; I; 2;
   Nb_aretes2; 1;
   o ; v ;

n_u ; I; 2;
   Nb_aretes2; 1;
   n ; u ;

f_v ; I; 2;
   Nb_aretes2; 1;
   f ; v ;

g_u ; I; 2;
   Nb_aretes2; 1;
   g ; u ;

a_t ; I; 2;
   Nb_aretes2; 1;
   a ; t ;
   
b_r ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes2; 1;
   b; r;
   x;
   R;
   
b_s ; I; 2;
   Nb_aretes2; 1;
   b ; s ;
   
u_v ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes; 1;
   u ; v ;
   Origine;
   1/2*epaisseur;

v_w ; I; 4; { arc de cercle passant par 2+1 points+RAYON }
   Nb_aretes; 1;
   v ; w ;
   Origine ;
   1/2*epaisseur;

@;


{******************************* DEFINITION DES SURFACES **********************} 
         3;
{ NOM DE LA SURFACE ou ABANDON?        }

A ; I; 1; { quadrangle algebrique }
   a_b ; b_r ; q_r ; a_q ;
   1;

X ; I; 1; { quadrangle algébrique }
   b_d ; d_j ; j_r ; b_r ;
   1; 

B ; I; 6; { triangle algébrique structuré }
   d_e ; e_j ; d_j ;

C ; I; 1; { quadrangle algebrique }
   e_f ; f_i ; i_j ; e_j ;
   1;

D ; I; 1; { quadrangle algebrique }
   f_g ; g_h ; h_i ; f_i ;
   1;

E ; I; 1; { quadrangle algebrique }
   i_j ; i_o ; o_r ; j_r ;
   1;

F ; I; 1; { quadrangle algebrique }
   h_i ; h_n ; n_o ; i_o ;
   1;

G ; I; 1; { quadrangle algebrique }
   o_r ; o_p ; p_q ; q_r ;
   1;

{ pour maillage de l'eau }

H ; I; 1; 
   b_d ; d_e ; e_s ; b_s ;
   1;

I ; I; 1; { quadrangle algébrique }
   e_f ; f_v ; s_v ; e_s ;
   1;

J ; I; 2; { quadrangle elliptique }
   f_g ; g_u ; u_v ; f_v ;
   0;

K ; I; 1; { quadrangle algébrique }
   s_v ; v_w ; t_w ; s_t ;
   1;

L ; I; 6; { triangle algébrique structuré }
   a_t ; q_t ; a_q ;

M ; I; 1; { quadrangle algébrique }
   s_t ; r_s ; q_r ; q_t ;
   1;

N ; I; 1; { quadrangle elliptique }
   e_j ; j_r ; r_s ; e_s ;
   1;

O ; I; 1; { quadrangle algébrique }
   s_v ; o_v ; o_r ; r_s ;
   1;

P ; I; 15; { rotation d'une ligne autour d'un axe }
   p_w ;
   Origine ; Origine_z;
   Nb_aretes;
   0; -45;

Q ; I; 15; { rotation d'une ligne autour d'un axe }
   o_v ;
   Origine ; Origine_z;
   Nb_aretes;
   0; -45;

R ; I; 1; { quadrangle algébrique }
   t_w ; p_w ; p_q ; q_t ;
   1;

S ; I; 2; { quadrangle elliptique }
   g_u ; g_h ; h_n ; n_u ;
   0;

U ; I; 2; { quadrangle elliptique }
   f_i ; i_o ; o_v ; f_v ;
   0;

V ; I; 1; { quadrangle algébrique }
   a_b ; b_s ; s_t ; a_t ;
   1;
   
W ; I; 6; { triangle algébrique structuré }
   b_s ; r_s ; b_r ;    

  
@;


