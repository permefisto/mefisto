{********************************************************************************} 
{******************************* DEFINITION DE L'OBJET **************************}
{********************************************************************************} 
DefFonc FTable(x,y,z);
     FTable=( z<= -( R*sin(teta)+eps-0.001) );
FinFonc;

DefFonc FPlastique(x,y,z);
     FPlastique=( ( z>= -( R*sin(teta)+eps )) ou (( z<= -( R*sin(teta)+eps) )
         et (abs(x)>=R*cos(teta)-0.015)) ou (( z<= -( R*sin(teta)+eps) )
         et (abs(y)>=R*cos(teta)-0.005) ));
FinFonc;

{DefFonc FBouchon(x,y,z);
     FBouchon=( (z>= (hauteur_cylindre+eps1))
               ou ((x*x+y*y)>= (1/2*epaisseur*1/2*epaisseur) ) );
FinFonc;}

3;
Table; I; 37; Plastique; FTable; 1;
Plastique; I; 37; gourde; FPlastique; 1;
{Bouchon; I; 37; bouchon; FBouchon; 1;}

@;
