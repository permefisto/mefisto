   3; { isometrie de R3 -> R3 }
   4; { symetrie par rapport a un plan defini par 3 points }
   Origine; g; h;

SymetrieOyz;
   3; { isometrie de R3 -> R3 }
   4; { symetrie par rapport a un plan defini par 3 points }
   Origine; a; p;
   
TranslationcA; 3; 0;    0; 0; R*sin(teta)+2*eps1+eps2;

TranslationcB; 3; 0;    0; 0; R*sin(teta)+eps1+eps2;

TranslationcC; 3; 0;    0; 0; R*sin(teta)+eps1;
 
TranslationcD; 3; 0;    0; 0; Hauteur_cylindre; 

TranslationcE; 3; 0;    0; 0; R*sin(teta);

TranslationcG; 3; 0;    0; 0; Hauteur_cylindre+eps1;

TranslationbH; 3; 0;    0; 0; eps1;

Ecrase_bouchon;     6;
   DefFonc XX(x,y,z);
        XX=x;
   FinFonc;

   DefFonc YY(x,y,z);
        YY=y;
   FinFonc; 

   DefFonc ZZ(x,y,z);
        ZZ=(z - (Hauteur_Cylindre+eps1) )/2+Hauteur_Cylindre+eps1;
   FinFonc;

  XX; YY; ZZ;

@;

