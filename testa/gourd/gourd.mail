DefFonc FBouchon(x,y,z);
   FBouchon=(z>= (Hauteur_cylindre-Hauteur_Bouchon-0.01));
FinFonc;

DefFonc FEau(x,y,z);
   Feau=(z <= (Hauteur_cylindre-2*Hauteur_Bouchon));
FinFonc;

DefFonc FAir(x,y,z);
   Fair=( (z<= (Hauteur_cylindre-Hauteur_Bouchon+0.005))
         et (z >= (Hauteur_cylindre-2*Hauteur_Bouchon-0.005) ) );
FinFonc; 

