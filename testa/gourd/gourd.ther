1;{ NOM de l OBJET a TRAITER }
  gourde;

2;{ ENTREE des DONNEES du PROBLEME }

{ VOLUME: AIR }
  1;     { Rot la densite de MASSE }
  1;     { constante }
  1.293; { DMASSE 'densite de masse'         reel   ; }

  2;     { [A] tenseur CONDUCTIVITE THERMIQUE }
  1;     { materiau 3D homogene isotrope }
  0.02;  { CONDUC  'conductivite du materiau'  reel   ; }

  7;     { C la CHALEUR MASSIQUE }
  1;     { constante }
  1004;  { CHAMAS 'chaleur massique'   reel   ; }

  8;     { TEMPERATURE INITIALE }
  1;     { constante }
  20;    { VATEM0 'temperature initiale constante'   reel   ; }
  @;

{ VOLUME: CYLINDRE_AIR }
  1;     { Rot la densite de MASSE }
