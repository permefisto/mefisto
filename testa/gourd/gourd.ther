 { SURFACE: TABLE }
  1;   { ECHANGE coefficient d echange avec le fluide a la paroi }
  1;   { constant }
 10;   { ECHANG 'coefficient d''echange'   reel   ; }

  2;   { SOURCE source de chaleur ou flux impose a la frontiere }
  1;   { constante }
 10*2; { SOURCE 'valeur de la source' reel ; }

  8;   { TEMPERATURE INITIALE }
  1;   { constante }
  20;  { VATEM0 'temperature initiale constante'   reel   ; }
@;
 
{ SURFACE: PLASTIQUE }
  1;   { ECHANGE coefficient d echange avec le fluide a la paroi }
  1;   { constant }
 10;   { ECHANG 'coefficient d''echange'   reel   ; }

  2;   { SOURCE source de chaleur ou flux impose a la frontiere }
  1;   { constante }
-10*10;{ SOURCE Temperature fluide * Echange }

  8;   { TEMPERATURE INITIALE }
  1;   { constante }
  20;  { VATEM0 'temperature initiale constante'   reel   ; }
@;

4; { CALCUL THERMIQUE INSTATIONNAIRE d/dt - div A grad temperature}
 1;{ CHALEUR MASSIQUE CONDUCTIVITE ECHANGE NE dependent PAS du TEMPS }
 0;{ TEMPS INITIAL }
 1;{ Temperature initiale constante de l'objet }
 5;{ VATEM0 temperature initiale constante }
 3600*10; { TEMPS FINAL  10 heures }
 3600/2;  { PAS DE TEMPS 1/2 heure }
     20;  { NOMBRE DE VECTEURS TEMPERATURES A STOCKER EN PLUS }
 2;{ GRADIENT CONJUGUE PRECONDITIONNE }
 0;{ NIVEAU FACTORISATION INCOMPLETE 0,1,... }
 1;{ 1/2 <= THETA de la METHODE <=1 +STABLE? }
@;
FERMER;
