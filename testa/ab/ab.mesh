1;{ POINTS vertices of the object }
 1;{ TYPING of VALUES }
   { NAME of the POINT or ESCAPE? }
 A; i; 1; 0; 0; 0;{ in LEXICON ~>TRANSFO }
   { X Y Z COORDINATES }
   { COORPO 'X Y Z of a point' xyz ; }
   { NAME of the POINT or ESCAPE? }
 B; i; 1; 1; 0; 0; { in LEXICON ~>TRANSFO }
   { X Y Z COORDINATES }
   { COORPO 'X Y Z of a point' xyz ; }
   { NAME of the POINT or ESCAPE? }
 @;

2;{ LINES edges of the object }
 AB; { NAME of the LINE or ESCAPE? }
 i; { NAME of TRANSFORMATION }
 2; { STRAIGHT LINE }
 20; { NBARLI 'number of edges of the line' entier ; }
 1; { RAIGEO 'geometrical ratio between the edges' reel ; }
 A; { NAME of POINT }
 B; { NAME of POINT }

 @;

5;  { OBJECTS parts of the object }
 AB; { NAME of the OBJECT or ESCAPE? }
 0;    { 1D or 2D or 3D classic }
 3;    { NBDOBJ 'number of Points Lines Surfaces Volumes Objects of the object' }
 l; AB;   { name of type PLSVO & PLSVO''s name }
 p; A;  { name of type PLSVO & PLSVO''s name }
 p; B;  { name of type PLSVO & PLSVO''s name }
 @;

7;  { INTERPOLATION nodes of the mesh }
 AB; { NAME of the OBJECT to be INTERPOLATED? }
  3;   { LAGRANGE of DEGREE 1 }
 @;

10; { DRAWING of PLSVO meshes }
 5;  { OBJECT or OBJECTS }
 1;  { ALL OBJECTS 1 by 1 }
