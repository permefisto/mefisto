@;
 0;  { EDGE LENGTH by DEFAULT }
  1; { LENGTH by DEFAULT of MESH EDGES? }

1; { POINTS vertices of the object }
 1;{ TYPING of VALUES }
 { NAME of the POINT or ESCAPE? }
 centri; i; 1; 1; 1; 1;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }
 centrs; i; 1; 11; 11; 11;
@;

3;{ SURFACES faces of the object }
 { NAME of the SURFACE or ESCAPE? }
 coneda; i;{ in LEXICON ~>TRANSFO }
 22;      { CLOSED SURFACE of a CONE }
 5; 8;    { RADIUS INFERIOR and SUPERIOR }
 centri; centrs; { CENTRE INFERIOR and SUPERIOR }


Deffunc Edge_Length(x,y,z);
   Edge_Length=Max(0.1*z,0.1);
EndFunc;

 coneti; i;{ in LEXICON ~>TRANSFO }
 22;      { CLOSED SURFACE of a CONE }
 5; 8;    { RADIUS INFERIOR and SUPERIOR }
 centri; centrs; { CENTRE INFERIOR and SUPERIOR }
@;


10; { DRAWING of PLSVO meshes }
 3; { SURFACE or SURFACES }
 1; { ALL SURFACES with 0 Tangent }
 75;{ Activate TRANSLATION ORBIT ZOOM }
 90;{ Continue the DRAWING }

