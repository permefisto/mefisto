@;
@;
DefVar t0,a,b,c,eps;
t0=1;
a=8;
b=6;
c=4;
eps=0.0001;

1; 1; {POINTS}
  ptdiag; i; 1; a; b; c;
@;
@;

4; { VOLUMES materials of the object }
  hexahedron;
   i;{ in the lexicon ~>TRANSFO }
  11;{ regular hexahedron with unit edges }
   a;{ NBINHX number of X-edges }
   b;{ NBINHY number of Y-edges }
   c;{ NBINHZ number of Z-edges }
@;

3;{ SURFACES faces of the object }

 base; i;{ in the lexicon ~>TRANSFO }
   37;   { EXTRACTED SURFACE FROM FACES OF A VOLUME }
 hexahedron;   { in the lexicon ~>VOLUME }
 DefFunc base(x,y,z); base=z<eps; EndFunc;
 base;   { in the lexicon ~>FONCTION }
    1;   { faces on boundary }

 top; i; 37; hexahedron;
 DefFunc top(x,y,z); top=z>c-eps; EndFunc;
 top; 1; { faces on boundary }

 back; i; 37; hexahedron;
 DefFunc back(x,y,z); back=x<eps; EndFunc;
 back; 1; { faces on boundary }

 front; i; 37; hexahedron;
 DefFunc front(x,y,z); front=x>a-eps; EndFunc;
 front; 1; { faces on boundary }

 left; i; 37; hexahedron;
 DefFunc left(x,y,z); left=y<eps; EndFunc;
 left; 1; { faces on boundary }

 right; i; 37; hexahedron;
 DefFunc right(x,y,z); right=y>b-eps; EndFunc;
 right; 1; { faces on boundary }
@;

5; { OBJECTS parts of the object }
 hexahedron; 0; { classic 2D ou 3D }
 8; { number of Points Lines Surfaces Volumes Objects of the object }
 v; hexahedron; { POINT or LINE or SURFACE or VOLUME or OBJECT? }
 s; top;        { name of type PLSVO and name of PLSVO}
 s; base;
 s; right;
 s; left;
 s; front;
 s; back;
 p; ptdiag;

 { NAME of the OBJECT or ESCAPE? }
@;

7; { INTERPOLATION definition of nodes of the mesh }
   hexahedron; { NAME of the OBJECT to be INTERPOLATED? }
   4; { LAGRANGE of DEGREE 2 }

 { NAME of the OBJECT to be INTERPOLATED? }
@;

10;
 { DRAWING of PLSVO meshes }
 5; { OBJECT }
 3; { ONE OBJECT }
 { NAME of the OBJECT? }
 hexahedron;
 90; { Continue the DRAWING }
 90; { Continue the DRAWING }

CLOSE;
