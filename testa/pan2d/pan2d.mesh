 DefVar xmin,      xmax,     ymin,   ymax,      EdgeMax;
        xmin=-0.1; xmax=0.1; ymin=0; ymax=0.08; EdgeMax=0.001;  { meters }
 DefVar nax; nax= (xmax-xmin)/EdgeMax;
 DefVar nay; nay= (ymax-ymin)/EdgeMax;  {To be EVEN }

19; { min MAX of PLSV }
 xmin; xmax;
 ymin; ymax;
    0;    0;

1;{ POINTS sommets of the object }
 1;{ FRAPPE des valeurs  NAME of POINT }
 A; i; 1; xmin; ymin; 0;
 { IN THE LEXICON ~>TRANSFO }
 { coordinates x y z }
 { COORPO '3 cartesien coordinates of point' xyz ; }
 { NAME du POINT or ESCAPE? }

 B;  i; 1; xmax; ymin; 0;
 C;  i; 1; xmax; ymax; 0;
 D;  i; 1; xmin; ymax; 0;
 ABMIDDLE; i; 1; 0;             0;    0;
 CDMIDDLE; i; 1; (xmin+xmax)/2; ymax; 0;      
 @;

 2; {LINES}
 AB; I; 2;
 { in LEXICON ~>TRANSFO }
 { STRAIGHT LINE }
 nax;
 { NBARLI 'number of edges of the line' entier ; }
 1;
 { RAIGEO 'geometrical ratio between the edges' reel ; }
 { NAME of POINT }
 A;
 { in LEXICON ~>POINT }
 { NAME of POINT }
 B;

 BC; i; 2; nay; 1; B; C;
 CD; i; 2; nax; 1; C; D;
 DA; i; 2; nay; 1; D; A;
 @;

 3;
 { SURFACES faces of the object }
 ABCDQ; i;{ IN THE LEXICON ~>TRANSFO }
 1; {transfinite  quadrangle}
 AB; BC; CD; DA;
 1; {regular mesh}

 ABCDT; i;  { name of TRANSFORMATION }
 31;        { Triangulation of a Quadrangulation }
 ABCDQ;     { name of initial SURFACE }
 1;         { creation of an EDGE S1 S3 }
 @;


 5;{ OBJECTS parts of the OBJECT }
 pan2d;   { name of the OBJECT }
 0;       { classic 2D or 3D }
 10;      { NBDOBJ number of Points Lines Surfaces Volumes Objects of the object}
 { POINT or LINE or SURFACE or VOLUME or OBJECT? }
 S; ABCDT; 
 L; AB;  L; BC;  L; CD;  L; DA;
 P;  A;  P;  B;  P;  C;  P;  D;  P; CDMIDDLE;
 { NTYOBJ(1..NBDOBJ) 'name of type PLSVO and name of PLSVO' typeobject }
 { name of OBJECT or ESCAPE? }
 @;

 7;   { INTERPOLATION NODES of the MESH }
 pan2d;  { name of the OBJECT to INTERPOLATE }
  4;     { LAGRANGE de DEGRE 2 => Triangles Taylor-Hood P2 }
 @;
 @;

10;  { DRAWINGS of the pan }
 5;  { OBJECT }
 1;  { ALL OBJECTS 1 by 1 }
 90; { Continue the DRAWING }

CLOSE;
