ExPressure(Vertex) = Exact Pressure at Vertex
PREXMI  = MIN( ExPressure(Vertex) )
PREXMX  = MAX( ExPressure(Vertex) )
PREXSOM = Sum( ABS( ExPressure(Vertex) ) )

CoPressure(Vertex) = Computed Pressure at Vertex
PRCAMI   = MIN( CoPressure(Vertex) )
PRCAMX   = MAX( CoPressure(Vertex) )
PRERRSOM = Sum( ABS( CoPressure(Vertex) - ExPressure(Vertex) ) )
PRERRAMX = MAX( ABS( CoPressure(Vertex) - ExPressure(Vertex) ) )
PRERRELA = ABS( ABS( CoPressure(Vertex) - ExPressure(Vertex) ) / ABS(ExPressure(Vertex)))

PRERRAMX                     = MAX ABS  PRESSURE ERROR = MAPE
PRERRAMX/(PREXMX-PREXMI)*100 = REL MAX  PRESSURE ERROR = RMPE
PRERRSOM/PREXSOM*100         = REL MEAN PRESSURE ERROR = MRPE

