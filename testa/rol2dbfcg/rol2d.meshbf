 hautxz;  { in LEXICON ~>SURFACE }

air; i; 51; 2; basxz; hautxz;
@;


2; { LINES edges of the object -------------------------------------}
 inlet; i; { in LEXICON ~>TRANSFO }
 37;  { EXTRACT INTERNAL OR BOUNDARY EDGES OF A SURFACE }
 air; { in LEXICON ~>SURFACE }
 { NAME of FUNCTION }
 DefFunc inlet(x,y,z);
   inlet=x<0.0001;
 EndFunc;
 inlet; { in LEXICON ~>FONCTION }
 1;     { BOUNDARY FACES }

 outlet; i; { in LEXICON ~>TRANSFO }
 37;  { EXTRACT INTERNAL OR BOUNDARY EDGES OF A SURFACE }
 air; { in LEXICON ~>SURFACE }
 { NAME of FUNCTION }
 DefFunc outlet(x,y,z);
   outlet=x>xmax-0.0001;
 EndFunc;
 outlet;  { in LEXICON ~>FONCTION }
 1;     { BOUNDARY FACES }

 top; i; { in LEXICON ~>TRANSFO }
 37;  { EXTRACT INTERNAL OR BOUNDARY EDGES OF A SURFACE }
 air; { in LEXICON ~>SURFACE }
 { NAME of FUNCTION }
 DefFunc top(x,y,z);
   top=y>zmax-0.0001;
 EndFunc;
 top;   { in LEXICON ~>FONCTION }
 1;     { BOUNDARY FACES }

 bottom; i; { in LEXICON ~>TRANSFO }
 37;  { EXTRACT INTERNAL OR BOUNDARY EDGES OF A SURFACE }
 air; { in LEXICON ~>SURFACE }
 { NAME of FUNCTION }
 DefFunc bottom(x,y,z);
   bottom=y<-zmax+0.0001;
 EndFunc;
 bottom;{ in LEXICON ~>FONCTION }
 1;     { BOUNDARY FACES }

 roll; i; { in LEXICON ~>TRANSFO }
 37;  { EXTRACT INTERNAL OR BOUNDARY EDGES OF A SURFACE }
 air; { in LEXICON ~>SURFACE }
 { NAME of FUNCTION }
 DefFunc roll(x,y,z);
   roll=(x-xc)**2 + y**2 < (rc+0.0001)**2;
 EndFunc;
 roll; { in LEXICON ~>FONCTION }
 1;      { BOUNDARY FACES }
 @;
@;

