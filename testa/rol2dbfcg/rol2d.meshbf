3;{ SURFACES faces of the object -------------------------------------}
 hautxz; i;{ in LEXICON ~>TRANSFO }
 9;{ TRIANGULATION1 BETWEEN CLOSED LINES }
 edgmax;{ ARETMX 'MAX length of edges of regular triangles' reel ; }
 1;{ NBLFTR 'NUMBER of closed lines contour of the surface' entier ; }
 0;{ NBPTIT 'NUMBER of internal points future vertices' entier ; }
 { NAME of LINE }
 haut;
 { in LEXICON ~>LIGNE }
 { NUPTIT(1..NBPTIT) 'NAME of internal points future vertices' }
 { DISOSV(1..NBPTIT) 'wished distance to the near vertices' reel ; }
 { NAME of the SURFACE or ESCAPE? }
 
basxz;
 symxy;   { in LEXICON ~>TRANSFO }
