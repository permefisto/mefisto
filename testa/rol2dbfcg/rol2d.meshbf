 DefVar xc;   xc=5;
 DefVar rc;   rc=0.5;
 DefVar xmax; xmax=25;  DefVar xmaxs2; xmaxs2=xmax/2;
 DefVar zmax; zmax=6;

 DefVar edgmin, edgmax;  edgmin=0.04; edgmax=0.4;
 DefFunc edge_length(x,y,z);
 DefVar d; d=sqrt((x-xc)**2+y**2);
 if x<xmaxs2; then
    edge_length=(edgmin*(xmaxs2-xc-d)+edgmax*d)/(xmaxs2-xc);
 else
    edge_length=edgmax;
 endif;
 EndFunc;

 0;      { EDGE LENGTH by DEFAULT --------------------------}
 edgmax; { LENGTH by DEFAULT of MESH EDGES? }

 1;   { POINTS vertices of the object---------------------- }
 1;   { TYPING of VALUES }
 a;   { NAME of the POINT or ESCAPE? }
 i;   { in LEXICON ~>TRANSFO }
 1;   { X Y Z COORDINATES }
 0; 0; 0; { COORPO 'X Y Z of a point' xyz ; }

 b; i; 1; xc-rc; 0; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 c; i; 1; xc; rc; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 d; i; 1; xc+rc; 0; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 e; i; 1; xmax; 0; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 f; i; 1; xmax; zmax; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 g; i; 1; 0; zmax; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 i; i; 1; 0; -zmax; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 k; i; 1; xmax; -zmax; 0;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }

 @;
@;


6;{ MAPPINGS R3-->R3 --------------------------------------------}
 { NAME of the TRANSFORMATION or ESCAPE? }
