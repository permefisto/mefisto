DefVar RC1232; RC1232=6.25 * RC123**2;

{ WISHED Edge_Length to SUBDIVIDE LINES TRIANGLES TETRAHEDRA }
DefFunc Edge_Length(x,y,z);
 if ( (x-CC123_X)**2 + (y-CC123_Y)**2 ) < RC1232 and z<2.5 then
    Edge_Length=0.02;
 else
    Edge_Length=0.05;
 endif;
 return;
EndFunc;


