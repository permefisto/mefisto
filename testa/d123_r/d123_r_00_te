 D1MOUTH_AX; i; 1; D1MOUTH_X+1; D1MOUTH_Y;   D1MOUTH_Z; { Axis Definition }
 D1MOUTH_AY; i; 1; D1MOUTH_X;   D1MOUTH_Y+1; D1MOUTH_Z;


DefVar D2MOUTH_X; D2MOUTH_X=D1MOUTH_X + distance * cos(-20*DegRad);
DefVar D2MOUTH_Y; D2MOUTH_Y=D1MOUTH_Y + distance * sin(-20*DegRad);
DefVar D2MOUTH_Z; D2MOUTH_Z=D1MOUTH_Z;

 D2MOUTH;    i; 1; D2MOUTH_X; D2MOUTH_Y; D2MOUTH_Z;
 D2MOUTH_AX; i; 1; D2MOUTH_X - cos(50*DegRad);
                   D2MOUTH_Y + sin(50*DegRad);
                   D2MOUTH_Z;

 D2MOUTH_AY; i; 1; D2MOUTH_X + cos(-140*DegRad);
                   D2MOUTH_Y + sin(-140*DegRad);
                   D2MOUTH_Z;


DefVar D3MOUTH_X; D3MOUTH_X=D1MOUTH_X + distance * cos(40*DegRad);
DefVar D3MOUTH_Y; D3MOUTH_Y=D1MOUTH_Y + distance * sin(40*DegRad);
DefVar D3MOUTH_Z; D3MOUTH_Z=D1MOUTH_Z;

 D3MOUTH;    i; 1; D3MOUTH_X; D3MOUTH_Y; D3MOUTH_Z;
 D3MOUTH_AX; i; 1; D3MOUTH_X + cos(-110*DegRad);
                   D3MOUTH_Y + sin(-110*DegRad);
                   D3MOUTH_Z;
 D3MOUTH_AY; i; 1; D3MOUTH_X + cos(-20*DegRad);
                   D3MOUTH_Y + sin(-20*DegRad);
                   D3MOUTH_Z;

{ Radius and Centre of Circle DENNIS 1 2 3 }
DefVar RC123;   RC123 = distance / 2 / cos(30*DegRad);
DefVar CC123_X, CC123_Y;
       CC123_X = D1MOUTH_X + RC123 * cos(10*DegRad);
       CC123_Y = D1MOUTH_Y + RC123 * sin(10*DegRad);

 CCD123; i; 1; CC123_X; CC123_Y;  D1MOUTH_Z;
