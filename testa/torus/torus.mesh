0;  { EDGE LENGTH by DEFAULT }
 1; { LENGTH by DEFAULT of MESH EDGES? }

1;{ POINTS vertices of the object }
 1;{ TYPING of VALUES }
 centre; i; 1; 5; 5; 5;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }
 axex; i; 1;  5;   5;  5+1;
 axey; i; 1;  5+1; 5;  5;
 @;

3;{ SURFACES faces of the object }
 torused; i;{ in LEXICON ~>TRANSFO }
 23;{ CLOSED SURFACE of a TORUS }
  1;{ RAPCTO 'GENERATOR SMALL CIRCLE RADIUS' reel ; }
  5;{ RAGCTO 'TRAVEL GREAT CIRCLE RADIUS' reel ; }
 centre; axex; axey; { NAME of POINT }

 DefFunc Edge_Length(x,y,z);
    Edge_Length = abs(z-5)*0.25 + 0.1;
 EndFunc;

 torusel; i;{ in LEXICON ~>TRANSFO }
 23;{ CLOSED SURFACE of a TORUS }
  1;{ RAPCTO 'GENERATOR SMALL CIRCLE RADIUS' reel ; }
  5;{ RAGCTO 'TRAVEL GREAT CIRCLE RADIUS' reel ; }
 centre; axex; axey; { NAME of POINT }

@;

10; { DRAWING of PLSVO meshes }
 3; { SURFACE or SURFACES }
 1; { ALL SURFACES with 0 Tangent }
 75;{ Activate TRANSLATION ORBIT ZOOM }
 90;{ Continue the DRAWING }
CLOSE;
