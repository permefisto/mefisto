 { NAME of TRANSFORMATION }
 i;
 { in LEXICON ~>TRANSFO }
 37;
 { EXTRACT SURFACE FROM FACES OF A VOLUME }
 { NAME of VOLUME }
 cylball;
 { in LEXICON ~>VOLUME }
 { NAME of FUNCTION }
 DefFunc ball(x,y,z);
 DefVar ray; ray=x*x + (y-l1)**2 + z*z;
 Ball=ray<1.0001*rb*rb;
 EndFunc;
 ball;
 { in LEXICON ~>FONCTION }
 1;
 { boundary faces }
 { NAME of the SURFACE or ESCAPE? }
 @;

