 @;
 @;
 DefVar pi; pi=atan(1)*4;
 DefVar rc, l1, l2;              {b=ball, c=cylinder}
        rc=0.05; l1=0.2; l2=0.6;
 DefVar lac; lac=(l1+l2)/70;

 defvar rb; rb=0.02;
 DefVar nbarb, lab; nbarb=8; lab=pi*rb/(2*nbarb);

 DefFunc FX(w,u,v);
   fx=rc*cos(v/rc);
 EndFunc;
 DefFunc fy(w,u,v);
   fy=u;
 EndFunc;
 DefFunc fz(w,u,v);
   fz=rc*sin(v/rc);
 EndFunc;

 6;
 { MAPPINGS R3-->R3 }
 { NAME of the TRANSFORMATION or ESCAPE? }
 cyl;
 6;
 { F:R3->R3 define by 3 functions (Fi) }
 { NAME of FUNCTION }
 fx; fy; fz;
 { in LEXICON ~>FONCTION }
 { in LEXICON ~>FONCTION }
 { in LEXICON ~>FONCTION }
 { NAME of the TRANSFORMATION or ESCAPE? }
 @;

 1;
 { POINTS vertices of the object }
 1;
 { TYPING of VALUES }
 { NAME of the POINT or ESCAPE? }
 a; i; 1; 0; 0; -pi*rc/2;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }
 b; i; 1; 0; l1+l2; -pi*rc/2;
 { in LEXICON ~>TRANSFO }
 { X Y Z COORDINATES }
 { COORPO 'X Y Z of a point' xyz ; }
 { NAME of the POINT or ESCAPE? }
 c; i; 1; 0; l1+l2; pi*rc/2;
