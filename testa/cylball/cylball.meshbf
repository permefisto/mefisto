 18;
 { 1/1 OF THE SURFACE OF A SPHERE }
 20*nbarb**2;
 { NBTRSP 'number of triangles (20*n**2)' entier ; }
 rb;
 { RAYOSP 'radius of the sphere' reel ; }
 { NAME of POINT }
 cb;
 { in LEXICON ~>POINT }
 { NAME of the SURFACE or ESCAPE? }
 @;
 @;


 DefFunc edge_length(x,y,z);
   DefVar dist; dist=sqrt( x*x + (y-l1)**2 + z**2 );
   edge_length=lac;
   if abs(y-l1) < 3.5*rb then
     edge_length=lac*0.5;
   endif;
   if dist < 2*rb then
     edge_length=abs( (dist-rb)*lac/2 + (2*rb-dist)*lab )/rb;
   endif;
 EndFunc;


