 abcd; i; 51; 4; ab; bc; cd; da;
 @;


 DefFunc edge_length(x,y,z);
   DefVar dist; dist=sqrt( x*x + (y-l1)**2 + z**2 );
   edge_length=lac;
   if abs(y-l1) < 3.5*rb then
     edge_length=lac*0.6;
   endif;
 EndFunc;


