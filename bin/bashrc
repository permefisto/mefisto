# Dans le repertoire $HOME ce fichier bashrc est a CONCATENER avec .bashrc

export MEFISTO=$HOME/git/mefisto 
export MEFISTOX=$HOME/mefistox

export PATH=.:$PATH:$MEFISTO/bin
export CDPATH=.:$HOME:$MEFISTO:$MEFISTOX

# Pour que OpenMP utilise 2 threads
export OMP_NUM_THREADS=2

alias ll='ls -l'
alias la='ls -a'
alias lla='ll -a'
alias lrt='ls -rtl'

export PS1="$(hostname):"'${PWD#}-bash-> '
echo "OMP_NUM_THREADS=$OMP_NUM_THREADS"
