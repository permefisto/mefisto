#!/bin/bash
# Fichier lignec      Alain PERRONNET  le 19 septembre 2002
#
# Calcul du nombre de lignes                  dans Mefisto
# Calcul du nombre de lignes     commentaires dans Mefisto
# Calcul du nombre de lignes non commentaires dans Mefisto
# set -x
echo
echo Calcul du nombre de lignes des sous-programmes fortran de Mefisto
echo ====================================================================================
nblt=0   #le nombre total de lignes des fichiers *.f
nblct=0  #le nombre total de lignes commentaires des fichiers .f
for i in `ls $MEFISTO`
do
  if test -d $MEFISTO/$i
  then
    echo librairie $MEFISTO/$i
    cd $MEFISTO/$i
    nbl=0      #le nombre de lignes des fichiers *.f de la librairie $i
    nblc=0     #le nombre de lignes commentaires des fichiers *.f de la librairie $i
#
    for j in `ls *.f`
    do
      nl=0                 #le nombre de lignes du fichier $j
      nlc=0                #le nombre de lignes commentaires du fichier $j
      set `wc $j` ; nl=$1
                           #grep -i ^C $j | set `wc` ; nlc=$1    se bloque dans `wc`
      grep -i ^C $j >fileC
      set `wc fileC` ; nlc=$1
      nbl=`expr $nbl + $nl`
      nblc=`expr $nblc + $nlc`
      echo $nl lignes dont $nlc lignes commentaires dans le fichier $j
    done
#
    nblt=`expr $nblt + $nbl`
    nblct=`expr $nblct + $nblc`
    echo
    echo Total pour la librairie $i : $nbl lignes dont $nblc lignes commentaires
    echo --------------------------------------------------------------------------------
    rm fileC 2>/dev/null
  fi
done

echo
echo ====================================================================================
echo Au total $nblt  lignes Fortran 77       dans les librairies Mefisto
echo Au total $nblct lignes commentaires f77 dans les librairies Mefisto
echo Au total `expr $nblt - $nblct` lignes instructions f77 dans les librairies Mefisto
echo ====================================================================================

