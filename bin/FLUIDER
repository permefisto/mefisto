#!/bin/bash
#  execution du solveur ecoulement de fluides de Mefisto par FLUIDER
#  Alain Perronnet Mars 2013 Version LINUX 64 bits + Fortran95 + OpenMP + Batch
#  Appel:
#  FLUIDER Nom du fichier des donnees de FLUIDER  (AVEC Nom =>Batch ou SANS   =>Interactif)
#                                                 (WITH Name=>Batch ou WITHOUT=>Interactif)

if test -f $MEFISTO/td/m/anglais
then
  LANGAGE=1
  LANGUE=ANGLAISE
  echo "Arguments Number=$#"
  echo "arg0=$0"
  echo "arg1=$1"
  echo "FLUIDER file NAME=$*"
  echo
  echo '======================================================================='
  echo 'MEFISTO-FLUIDER: Solver of a FLUID PROBLEM under LINUX 64 bits + OpenMP'
  echo '======================================================================='
  echo 'Project (low case) name' \?
else
  LANGAGE=0
  LANGUE=FRANCAISE
  echo "Nombre Arguments=$#"
  echo "arg0=$0"
  echo "arg1=$1"
  echo "Nom du Fichier FLUIDER=$*"
  echo
  echo '==========================================================================='
  echo 'MEFISTO-FLUIDER: Resoudre un Probleme de FLUIDE sous LINUX 64 bits + OpenMP'
  echo '==========================================================================='
  echo 'nom (en minuscules) du projet' \?
fi
read nomproj

echo
# Demande du nombre de threads
#if [ $LANGAGE = 0 ]
#then
#   echo 'Nombre de threads en execution de FLUIDER' \?
#else
#   echo 'Number of threads on FLUIDER execution' \?
#fi
#read   OMP_NUM_THREADS
#export OMP_NUM_THREADS
echo   OMP_NUMBER_THREADS=$OMP_NUM_THREADS

direxec=$MEFISTOX/$nomproj
if [ $LANGAGE = 0 ]
then
  echo "Execution MEFISTO FLUIDER dans repertoire $direxec avec $OMP_NUM_THREADS threads"
else
  echo "Execution MEFISTO FLUIDER in the directory $direxec on $OMP_NUM_THREADS threads"
fi

if test -d $direxec
then
  cd  $direxec
  time $MEFISTO/pp/ppflui $*
else  
  if [ $LANGAGE = 0 ]
  then
    echo Commande INITIER non prealablement executee
    echo "avec ce nom de projet $nomproj"
    echo Executer INITIER puis MAILLER
  else
    echo Command INITIER NOT EXECUTED BEFORE
    echo "with this project name $nomproj"
    echo Execute INITIER and after MESHER
  fi
fi

echo
