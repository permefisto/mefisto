#!/bin/bash
#  execution du solveur thermique de Mefisto par ELASTICER
#  Alain Perronnet  Octobre 2012   Version LINUX 64 bits
#   
if test -f $MEFISTO/td/m/anglais
then
  LANGAGE=1
  LANGUE=ANGLAISE
  echo
  echo '=========================================================================='
  echo 'MEFISTO-ELASTICER_OMP: Solver of an ELASTICITY PROBLEM under LINUX 64 bits'
  echo '=========================================================================='
  echo 'Project (low case) name' \?
else
  LANGAGE=0
  LANGUE=FRANCAISE
  echo
  echo '====================================================================='
  echo 'MEFISTO-ELASTICER_OMP: Resoudre un PB d ELASTICITE sous LINUX 64 bits'
  echo '====================================================================='
  echo 'nom (en minuscules) du projet' \?
fi
read nomproj

direxec=$MEFISTOX/$nomproj
echo
if [ $LANGAGE = 0 ]
then
  echo "Execution MEFISTO ELASTICER_OMP dans le repertoire $direxec"
else
  echo "Execution MEFISTO ELASTICER_OMP in the directory $direxec"
fi

if test -d $direxec
then
  cd  $direxec 
  export OMP_NUM_THREADS=8
  echo "OMP_NUM_THREADS="$OMP_NUM_THREADS
  time $MEFISTO/pp/ppelas
else  
  if [ $LANGAGE = 0 ]
  then
    echo Commande INITIER non prealablement executee
    echo "avec ce nom de projet $nomproj"
    echo Executer INITIER puis MAILLER
  else
    echo Command INITIER NOT EXECUTED BEFORE
    echo "with this project name $nomproj"
    echo Execute INITIER and after MESHER
  fi
fi
