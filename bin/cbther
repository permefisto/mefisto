#!/bin/bash
#
# compilation et edition de liens de ppther.f 
# Alain Perronnet   Version LINUX 64bits    Septembre 2009

cd $MEFISTO
#Creation du repertoire pp s'il n'existe pas
if !(test -d pp)
then
  mkdir pp
fi

if test -f $MEFISTO/td/m/anglais
then
  LANGAGE=1
  LANGUE=ANGLAISE
  echo
  echo ====================================================================
  echo MEFISTO-LINUX 64bits: Compilation f+OpenMp + Link Editor of ppther.f
  echo ====================================================================
else
  LANGAGE=0
  LANGUE=FRANCAISE
  echo
  echo =========================================================================
  echo MEFISTO-LINUX 64bits: Compilation f+OpenMp + Edition de liens de ppther.f
  echo =========================================================================
fi

#  
# compilation de xvuelc.c
if !(test -f xvue/xvuelc.o)
then
  bin/ccxvue
fi

nompp=pp/ppther
if test -f $nompp
then
  rm $nompp
fi

### g77 -g -I.  prpr/ppther.f ther/lib util/lib xvue/lib xvue/xvuelc.o \
###     -lXt -lX11 -lXext -o $nompp

echo "gfortran -m64 -fPIC -O -fopenmp -I. $MEFISTO/prpr/ppther.f -o $nompp"
gfortran -m64 -fPIC -O -fopenmp -I. prpr/ppther.f ther/lib reso/lib mail/lib \
                util/lib xvue/lib xvue/xvuelc.o \
    -lgfortran -L/usr/X11R6/lib64 -lX11 -o $nompp

if test -f ppther.o
then
  rm ppther.o
fi

if test -f $nompp
then 
  chmod 755 $nompp
  ls -l $MEFISTO/pp
  echo
  if [ $LANGAGE = 0 ]
  then
    echo "$MEFISTO/$nompp est CORRECT pour executer THERMICER"
  else
    echo "$MEFISTO/$nompp is CORRECT to execute HEATER"
  fi
else
  if [ $LANGAGE = 0 ]
  then
    echo "$MEFISTO/$nompp est INCORRECT. THERMICER est NON EXECUTABLE"
  else
    echo "$MEFISTO/$nompp is INCORRECT. HEATER is NOT EXECUTABLE"
  fi
fi
