deffonc k(n);        { un exemple a ne pas suivre! }
defetiq e1,e2;
aller e2;
e1: k=n*n;
retour;
e2: aller e1;
finfonc;   

deffonc f(n);        { Exemple de boucle pour }
   defvar i; 
   f=1;
   pour i=1 a n ;
      f=f*i;
   finpour;
finfonc;
f(5);

deffunc fpur(n);     { en franglais }
defvar i,j;
fpur=0;
for i=1 to n;
  for j=1 to 3;
     fpur=fpur+i+j;
  endfor;
finpour;
display fpur;
endfunc;
fpur(2);

deffonc fa(n);       { Exemple de tant que }
   defvar i;
   fa=1; i=0; 
   tantque i<n ;
      i=i+1 ;
      fa=fa*i ;
   fintant;
finfonc; 
fa(5);  

deffunc ftantq(n);   { en franglais }
defvar i,j;
ftantq=0;
i=0;
tantque i<n;
   i=i+1;
   j=0;
   while j<=3;
      j=j+1;
      ftantq=ftantq+i+j;
   endwhile;
fintant;
display ftantq;
return;
endfunc;
display ftantq(2);

deffonc fac(n);      { Exemple de repeter ... jusque }
   defvar i;
   fac=1; i=0;
   repeter
      i=i+1; 
      fac=fac*i;
   jusque i=n;
finfonc;
fac(5); 
        
deffunc frep(n);     { en franglais }
defvar i,j;
frep=0; i=0;
repeat;
  i=i+1; j=0;
  repeter ;
    j=j+1;
    frep=frep+i+j;
  jusque j>4;
until i>=n;
endfunc;
display frep(2);

