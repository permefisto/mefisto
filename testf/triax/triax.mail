 defvar pi4,pi,pi2,pi15; 
        pi4=atan(1); pi2=pi4*2; pi=pi4*4; pi15=pi/15;
 defvar p40d; 
        p40d=pi/180*40;  
                                
 defvar h,rac2,rac3;
  h=4; rac2=sqrt(2); rac3=sqrt(3);

 defvar rc,r1,r2,ra,ran,rane,ratr,rconge,ep,ep0,ep1,ep2;
 rc=20; r1=119/2; r2=131/2; ran=46; ra=8.5; rane=ran+ra; ratr=52/2; rconge=2;
 ep1=12; ep2=ep1+rc;  ep=3; ep0=ep1-ep;

 defvar na1,na2,na3,na4,na5,na6,na7,na8,na9,na10,naep1,naep2,naconge;
 na1=rc*pi4/h; na2=27/h; na3=na1; na4=ra/h; na5=max(1,ep/h);
 na6=(r2-rane)/h; na7=(r2-rc*rac2)*pi4/h; na8=(r1-rc*rac2)*pi4/h;
 na9=max(2,(r2-r1)/h); na10=(r1-(rc+r2-r1)*rac2)/h;
 naep1=ep1/h; naep2=rc/h; naconge=3;

6;   { TRANSFORMATIONS mathematiques sur les objets }  
 deffonc idx(x,y,z); idx=x;      finfonc;
 deffonc idy(x,y,z); idy=y;      finfonc;
 deffonc idz(x,y,z); idz=z;      finfonc;  

 deffonc zep1(x,y,z); zep1=z+ep1;  finfonc;
 deffonc zep2(x,y,z); zep2=z+ep2;  finfonc;

 transz_ep1;     6;   idx;  idy;   zep1;
 transz_ep2;     6;   idx;  idy;   zep2;   

 deffonc py(x,y,z);  py=rc*asin(y/rc); finfonc;       
 deffonc py0(x,y,z); py0=(rc+ep)*asin(y/(rc+ep)); finfonc;
 deffonc pz(x,y,z);  pz=0;  finfonc;  
  
 deffonc pm1y0(x,y,z); pm1y0= (rc+ep)*sin(y/(rc+ep));     finfonc;
 deffonc pm1z0(x,y,z); pm1z0=-(rc+ep)*cos(y/(rc+ep))+ep2; finfonc; 
     
 deffonc pm1y(x,y,z); pm1y= rc*sin(y/rc);     finfonc;
 deffonc pm1z(x,y,z); pm1z=-rc*cos(y/rc)+ep2; finfonc;
 deffonc pxz(x,y,z); pxz=z; finfonc;
 deffonc pzx(x,y,z); pzx=x; finfonc;
 deffonc pycz2(x,y,z); 
   si x>1e-5 
   alors pycz2=r2*atan(y/x);
   sinon pycz2=r2*pi2;
   finsi;
 finfonc;       
 deffonc pycz1(x,y,z); 
   si x>1e-5 
   alors pycz1=r1*atan(y/x);
   sinon pycz1=r1*pi2;
   finsi;
 finfonc;       
 deffonc pycz(x,y,z); 
   si x>1e-5 
   alors pycz=rc*atan(y/x);
   sinon pycz=rc*pi2;
   finsi;
 finfonc;

 deffonc pm1czx1(x,y,z); pm1czx1=r1*cos(y/r1); finfonc;
 deffonc pm1czy1(x,y,z); pm1czy1=r1*sin(y/r1); finfonc; 
     
 deffonc pm1czx2(x,y,z); pm1czx2=r2*cos(y/r2); finfonc;
 deffonc pm1czy2(x,y,z); pm1czy2=r2*sin(y/r2); finfonc; 

 deffonc pm1czx(x,y,z); pm1czx=rc*cos(y/rc); finfonc;
 deffonc pm1czy(x,y,z); pm1czy=rc*sin(y/rc); finfonc;

 aplatir0;  6;  idx; py0;  pz; 
 aplatir;   6;  idx; py;   pz;  
 aplatirz1; 6;  pxz; pycz1; pz;  
 aplatirz2; 6;  pxz; pycz2; pz;  
 aplatirz;  6;  pxz; pycz; pz;  

 arrondir;   6;  idx;    pm1y;    pm1z;  
 arrondir0;  6; idx;     pm1y0;   pm1z0; 
 arrondirz1; 6; pm1czx1; pm1czy1; pzx;  
 arrondirz2; 6; pm1czx2; pm1czy2; pzx;   
 arrondirz;  6; pm1czx ; pm1czy;  pzx;
@; 

 20;     {modification de la PRECISION  pour identifier des points}
  1;     {Autour d''un POINT NON ORIGINE }
 1E-3;
@;

 1; 1;   { POINTS principaux de l objet }
 o;  i;1; 0;0;0;
 x1; i;1; rc;0;0;
 x2; i;1; ran;0;0;
 x3; i;1; rane;0;0;
 x4; i;1; r2;0;0;
 b1; i;1; rc;rc;0;
 b2; i;1; ratr;ratr;0;
 b3; i;1; R1/rac2; R1/rac2; 0;
 b4; i;1; R2/rac2; R2/rac2; 0;
 c1; i;1; rane; rc; 0;
 c2; i;1; rane; (rc+ep); 0;
 c3; i;1; ran; (rc+ep); 0;
 c4; i;1; ran; rc; 0;
 c5; i;1; sqrt( R2**2 - (rc+ep)**2 ); (rc+ep); 0;    
 b0; i;1; rc/rac2; rc/rac2; 0; 
 ab; i; 1; rc/rac2; rc/rac2;  ep2-rc/rac2; 

 cz; i;1; rc*rac3/2;  10; 0;
 cze;i;1; R2*rac3/2;  R2/2; 0;
 d1; i;1; sqrt(r1**2-ratr**2); ratr; 0; 
 d3; i;1; sqrt(r1**2-(ratr+rconge)**2); ratr+rconge; 0; 
 d2; i;1; sqrt(r1**2-ratr**2)-rconge; ratr; 0; 

 czb;i;1; r2*cos(pi15); r2*sin(pi15); 0;  
 czi;i;1; r1*cos(p40d); r1*sin(p40d); 0; 
 x;i;1;   1;  0;  0;
 y;i;1;   0;  1;  0;
 z;i;1;   0;  0;  1; 
 zmep2;i; 1; 0; 0; 1-ep2;      
 mx;i;1; -1;  0;  0;
 my;i;1;  0; -1;  0;
 mz;i;1;  0;  0; -1;

 x1z1; transz_ep1; 50; x1; 
 x4z1; transz_ep1; 50; x4; 
 d1z1; transz_ep1; 50; d1; 
 d2z1; transz_ep1; 50; d2; 
 d3z1; transz_ep1; 50; d3; 

 b1z1; transz_ep1; 50; b1; 
 b2z1; transz_ep1; 50; b2;    
 b3z1; transz_ep1; 50; b3;

 b1z2; transz_ep2; 50; b1; 
 b2z2; transz_ep2; 50; b2;    
 b3z2; transz_ep2; 50; b3;
 b4z2; transz_ep2; 50; b4;   
 c1z2; transz_ep2; 50; c1;
 c2z2; transz_ep2; 50; c2;    
 c3z2; transz_ep2; 50; c3;
 c4z2; transz_ep2; 50; c4; 
 c5z2; transz_ep2; 50; c5; 
 d1z2; transz_ep2; 50; d1;   
 d2z2; transz_ep2; 50; d2; 
 d3z2; transz_ep2; 50; d3; 

 cerx0;  i; 1; rane; 0;         ep0;
 cerx1;  i; 1; rane; 0;         ep1;
 cerx2;  i; 1; rane; rc/2;      ep2-rc*rac3/2; 
 cerxrc; i; 1; rane; (rc+ep)/2; ep2-(rc+ep)*rac3/2; 
 x4z0;   i; 1; r2;   0; ep0;
@;    

6;   { TRANSFORMATIONS mathematiques sur les objets }  
 rotzp90;  3; 1; O; z; -90; 0; 0; ep2; 1; 1; 1;
 rotyp90;  3; 1; O; y;  90; 0; 0; ep2; 1; 1; 1;
 roty90;   3; 3;    o; x; y;  o; mz; y;
@;

2;        { LIGNES aretes de l objet }
 x1b0;i;3; na1;  1;  X1; B0;  CZ;
 x1x2;i;2; na2;  1;  X1;  X2;
