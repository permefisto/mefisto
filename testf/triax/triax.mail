{ conge2;i; 28; naconge; rconge; d2z2; d1z2; d3z2;  }
  conge1;i; 2; 1; 1; d2z1; d3z1;
  conge2;i; 2; 1; 1; d2z2; d3z2;

 d2d2; i; 2; naep2; 1; d2z1; d2z2;  
