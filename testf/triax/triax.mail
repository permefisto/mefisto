 cxcz;  transz_ep2; 27;  { intersection 2 demi-cylindres d axes Y Z } 
 na1; { NBARLI 'nombre d''aretes de la ligne intersection' entier ; } 
   1; { axe des X }
  rc; { RAYCAY 'rayon cylindre CY d''AXE Y (>R2)'  reel ; }
  rc; { RAYCAZ 'rayon cylindre CZ d''AXE Z (<R1)'  reel ; }
   0; { AL0CAZ 'longitude initiale en degres'      reel ; }
  45; { AL1CAZ 'longitude finale   en degres'      reel ; }
  -1; { COTCAZ 'cote z>0 ou z<0 (1 ou -1)' reel ;}          

 cxcy;  rotyp90; 27;  { intersection 2 demi-cylindres d axes Y Z } 
 na1; { NBARLI 'nombre d''aretes de la ligne intersection' entier ; } 
   2; { axe des Y }
  rc; { RAYCAY 'rayon cylindre CY d''AXE Y (>R2)'  reel ; }
  rc; { RAYCAZ 'rayon cylindre CZ d''AXE Z (<R1)'  reel ; }
  45; { AL0CAZ 'longitude initiale en degres'      reel ; }
  90; { AL1CAZ 'longitude finale   en degres'      reel ; }
   1; { COTCAZ 'cote z>0 ou z<0 (1 ou -1)' reel ;}       

 CZcx;  roty90; 27;  { intersection 2 demi-cylindres d axes Y Z } 
 na1+na3;  { NBARLI 'nombre d''aretes de la ligne intersection' entier ; } 
   1;      { axe des x }
  R2;      { RAYCAY 'rayon cylindre CX d''AXE X (>R2)'  reel ; }
  rc+ep;   { RAYCAZ 'rayon cylindre CZ d''AXE Z (<R1)'  reel ; }
   0;      { AL0CAZ 'longitude initiale en degres'      reel ; }
  90;      { AL1CAZ 'longitude finale   en degres'      reel ; }
   1;      { COTCAZ 'cote z>0 ou z<0 (1 ou -1)' reel ;}  

 CZcxz0;  transz_ep2; 50; CZcx;
                    
 cerx1;  i; 3; na1+na3; 1; cerx1;  c1z2;  cerx2; 
 cerx10; i; 3; na1+na3; 1; cerx0;  c2z2;  cerxrc; 
 cx1cx0; i; 2; na5;     1; cerx1; cerx0; 
