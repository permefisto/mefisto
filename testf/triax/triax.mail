4;     { VOLUMES parties de l objet }
 triax8;i;8;  { un volume ferme d un volume pour option 9 }
 1;           { NBSF1V 'nombre de surfaces fermees contour du volume' entier ; }
 triaxs;      { DANS LE LEXIQUE ~>SURFACE }

 triax9;i;9;  { le volume union de volumes fermes de type 8 }
 10000;       { MXSOVO 'nombre maximal de sommets de la tetraedrisation' }
 h;           { ARETGR 'longueur de l''arete de la grille reguliere' } 
 3;           { ANTE2P 'degres du petit angle de coplanearite' }
 0;           { NBPTIV 'nombre de points internes fournis par l''utilisateur' }
 1;           { NBVOPA 'nombre de volumes de type 8 de la partition' entier ; }
 triax8;      { DANS LE LEXIQUE ~>VOLUME } 
  
 triaxa; i; 30;  { amelioration d une tetraedrisation }
     triax9;     { DANS LE LEXIQUE ~>VOLUME }
      0.3;       { QUTEMN 'qualite au dessous de laquelle ameliorer' }
        3;       { ANTE2P 'degres du petit angle de coplanearite' }
        8;       { NBITAT 'nombre des iterations pour ameliorer'  }
@;  

