{ ======================================================================== }
 DefVar edgel;  edgel=2.0;  {edge length of triangles}
{DefVar edgel;  edgel=3.6; 3.2; 2.4; 1.5 PB MC {edge length of triangles}}
{DefVar edgel;  edgel=1.8;  PB MC with fluxes}

DefVar ednb; ednb=10; {edge number :      not efficient Taille_Ideale exists}
DefVar gera; gera=1;  {geometrical ratio: not efficient Taille_Ideale exists}

DefVar hx; hx=10;     {hexahedron length/2}
DefVar hy; hy=10;     {hexahedron width/2 }
DefVar hz; hz= 6;     {hexahedron height/3}

DefVar px; px=6;      {pyramid length/2}
DefVar py; py=6;      {pyramid width/2 }
DefVar pz; pz=6;      {pyramid height  }

DefFunc Taille_Ideale(x,y,z);
DefVar d0, dist;
d0=pz*0.4;
dist=sqrt( x*x+y*y+(z-pz*0.4)**2 );
if (dist<d0)
then Taille_Ideale=edgel*0.5;
else Taille_Ideale=edgel*( 0.5*(hx-dist) + dist-d0 ) / (hx-d0);
endif;
EndFunc;

1; 1;   {POINTS}

h1; i; 1; -hx; -hy; -hz;  {The HEXAHEDRON}
h2; i; 1;  hx; -hy; -hz;
h3; i; 1;  hx;  hy; -hz;
h4; i; 1; -hx;  hy; -hz;
h5; i; 1; -hx; -hy;  hz*2;
h6; i; 1;  hx; -hy;  hz*2;
h7; i; 1;  hx;  hy;  hz*2;
h8; i; 1; -hx;  hy;  hz*2;

p1; i; 1; -px; -py;  0;    {The PYRAMID}
p2; i; 1;  px; -py;  0;
p3; i; 1;  px;  py;  0;
p4; i; 1; -px;  py;  0;
p5; i; 1;  0;    0; pz;
@;

2;  {LINES}
h1h2; i; 2; ednb; gera; h1; h2;  {HEXAHEDRON EDGES}
h2h3; i; 2; ednb; gera; h2; h3;
h3h4; i; 2; ednb; gera; h3; h4;
h4h1; i; 2; ednb; gera; h4; h1;

h1h5; i; 2; ednb; gera; h1; h5;
h2h6; i; 2; ednb; gera; h2; h6;
h3h7; i; 2; ednb; gera; h3; h7;
h4h8; i; 2; ednb; gera; h4; h8;

h5h6; i; 2; ednb; gera; h5; h6;
h6h7; i; 2; ednb; gera; h6; h7;
h7h8; i; 2; ednb; gera; h7; h8;
h8h5; i; 2; ednb; gera; h8; h5;

p1p2; i; 2; ednb; gera; p1; p2;  {PYRAMID EDGES}
p2p3; i; 2; ednb; gera; p2; p3;
p3p4; i; 2; ednb; gera; p3; p4;
p4p1; i; 2; ednb; gera; p4; p1;

p1p5; i; 2; ednb; gera; p1; p5;
p2p5; i; 2; ednb; gera; p2; p5;
p3p5; i; 2; ednb; gera; p3; p5;
p4p5; i; 2; ednb; gera; p4; p5;
@;

3;  {SURFACES}
h1h2h3h4; i; 1; h1h2; h2h3; h3h4; h4h1; 1;  {HEXAHEDRON FACES}
h1h2h6h5; i; 1; h1h2; h2h6; h5h6; h1h5; 1;
h2h3h7h6; i; 1; h2h3; h3h7; h6h7; h2h6; 1;
h3h4h8h7; i; 1; h3h4; h4h8; h7h8; h3h7; 1;
h4h1h5h8; i; 1; h4h1; h1h5; h8h5; h4h8; 1;
h5h6h7h8; i; 1; h5h6; h6h7; h7h8; h8h5; 1;

p1p2p3p4; i; 1; p1p2; p2p3; p3p4; p4p1; 1;  {PYRAMID FACES}
p1p2p5;   i; 6; p1p2; p2p5; p1p5;
p2p3p5;   i; 6; p2p3; p3p5; p2p5;
p3p4p5;   i; 6; p3p4; p4p5; p3p5;
p4p1p5;   i; 6; p4p1; p1p5; p4p5;

hexa; i; 51; 6; h1h2h3h4; h1h2h6h5; h2h3h7h6; h3h4h8h7; h4h1h5h8; h5h6h7h8;
pyra; i; 51; 5; p1p2p3p4; p1p2p5;   p2p3p5;   p3p4p5;   p4p1p5;

hexat; i; 31; hexa; 1; {create an edge S1 S3} 
pyrat; i; 31; pyra; 1; {create an edge S1 S3} 
@;

4; {VOLUMES}
hexav8;   i; 8; 2; hexat; pyrat; {Volume 8 for Volume 9}
pyrav8;   i; 8; 1; pyrat;
hexpyrt;  i; 9; 100000; edgel; 5; 0; 2; hexav8; pyrav8; {Tetrahedrization}
@;

5; {OBJECT}
hexapyra; 0; 3;
     v; hexav8;  v; pyrav8;  s; hexav8.F;  {hexav8.I2 exists so}
@;

7; {INTERPOLATION}
 hexapyra;
 4;  { Lagrange degree 2 }
@;

10;  { Drawing of PLSVO }
 5;  { All OBJECTS }
 90; { Execution of Drawing }
@;
@;

Close;
