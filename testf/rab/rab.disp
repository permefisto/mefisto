@;
     {==================================================}
3;   { SOLUTION of the LINEAR STEADY ELASTICITY PROBLEM }
     {==================================================}
  1; { INDEPENDENT COEFFICIENTS of TIME and DISPLACEMENTS }
  2; { THERMO-ELASTICITY }
  1; { Solution by factorization CHOLESKY on skyline storage }
@;

     {=====================================================================}
4;   { SOLUTION of the UNSTEADY ELASTICITY PROBLEM on [0,1] TIME INTERVAL  }
     {=====================================================================}
{Modification to add the acceleration in the FORCE user's function}
DefFunc force(t,x,y,z,nutype,nuobj,ncomp,xn,yn,zn);
  if ncomp=1 then
    force = Rot*dttu1(t,x,y) - dxsig11(t,x,y) - dysig12(t,x,y) + cu1*u1(t,x,y);
  else
    force = Rot*dttu2(t,x,y) - dxsig12(t,x,y) - dysig22(t,x,y) + cu2*u2(t,x,y);
  endif;
EndFunc;
{Others data are inchanged for the unsteady problem }

  1;          { [M] [K] are INDEPENDENTS of TIME but f DEPENDS of TIME }
  2;          { THERMO-ELASTICITY }
  0;          { MASS      DUMPING COEFFICIENT }
  0;          { STIFFNESS DUMPING COEFFICIENT }
  0.0;        { INITIAL TIME }
  2;          { INITIAL DISPLACEMENT from the steady solution }
 -1;          { INITIAL VELOCITY by function }
 vitesseinit; { in the lexicon ~>FONCTION }
nbpas*DeltaT; { FINAL TIME }
 DeltaT;      { CONSTANT STEP of TIME }
 nbpas;       { NUMBER of VECTORS to STORE => ALL }
  1;          { Solution by factorization CHOLESKY on skyline storage }
  1;          { TIME INTEGRATION by the NEWMARK's SCHEME }
@;

     {=======================================================================}
4;   { SOLUTION of the UNSTEADY ELASTICITY PROBLEM on [2,1] TIME INTERVAL    }
     {=======================================================================}
  1;          { [M] [K] are INDEPENDENTS of TIME but f DEPENDS of TIME }
  2;          { THERMO-ELASTICITY }
  0;          { MASS      DUMPING COEFFICIENT }
  0;          { STIFFNESS DUMPING COEFFICIENT }
nbpas*DeltaT; { INITIAL TIME }
  3;          { DEPLACEMENT INITIAL a partir du DEPLACEMENT a t=0.8 et t=1.0 }
2*nbpas*DeltaT; { TEMPS FINAL de l'etude }
 DeltaT;      { CONSTANT STEP of TIME }
 nbpas;       { NUMBER of VECTORS to STORE => ALL }
 2; 1;        {  Solution by PRECONDITIONED CONJUGATE GRADIENT by 1 LEVEL }
  1;          { TIME INTEGRATION by the NEWMARK's SCHEME }
@;
@;

8; {Drawing of DISPLACEMENTS and STRESSES}
 1; 90; 90; {Drawing of stresses}

