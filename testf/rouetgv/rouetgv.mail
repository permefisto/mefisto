 DEFFONC DROITE(X,Y,Z); DROITE=(X>459) ET (X>477 OU Y>31); FINFONC; 

2;
 { LIGNES ARETES DE L OBJET }
 BAS;  I;     { DANS LE LEXIQUE ~>TRANSFO }
      37;     { EXTRACTION D UNE LIGNE D UNE SURFACE }
 ROUE.TGV;    { DANS LE LEXIQUE ~>SURFACE }
    BASE;     { DANS LE LEXIQUE ~>FONCTION }
       1;     { ARETES FRONTALIERES }  

 HAUT; I; 37; { DANS LE LEXIQUE ~>TRANSFO }  { EXTRACTION D UNE LIGNE D UNE SURFACE }
 ROUE.TGV;    { DANS LE LEXIQUE ~>SURFACE }
 HAUT;        { DANS LE LEXIQUE ~>FONCTION }
           1; { ARETES FRONTALIERES }  

 GAUCHE; I; 37; ROUE.TGV;   { EXTRACTION D UNE LIGNE D UNE SURFACE }
 GAUCHE;                   { DANS LE LEXIQUE ~>FONCTION }
            1;             { ARETES FRONTALIERES } 

 DROITE; I; 37;      { EXTRACTION D UNE LIGNE D UNE SURFACE }
 ROUE.TGV;           { DANS LE LEXIQUE ~>SURFACE }
 DROITE;             { DANS LE LEXIQUE ~>FONCTION }
            1;       { ARETES FRONTALIERES }

 CONTOUR; I; 51; 4; BAS; DROITE; HAUT; GAUCHE;  {UNION DES 4 LIGNES}

@;

