 TRIANGU; I; 9; { TRIANGULATION D UN CONTOUR DE LIGNES FERMEES }
  24;     { ARETMX 'TAILLE MAX DES ARETES DES TRIANGLES EQUILATERAUX' REEL ; }
   1;     { NBLFTR 'NOMBRE DE LIGNES FERMEES CONTOUR DE LA SURFACE' ENTIER ; }
