3;
 DEFFONC EXTRAC_DEMI1(X,Y,Z);
 EXTRAC_DEMI1 = (Y>0) ET ((X**2 + (Z-7.3)**2) < 1.501**2) ET (X<0.001);
 FINFONC;
 
 CONTACT1;I;37;ENTIER;EXTRAC_DEMI1;1;

 DEFFONC EXTRAC_DEMI2(X,Y,Z);
 EXTRAC_DEMI2 = (Y<0) ET ((X**2 + (Z-7.3)**2) < 1.501**2) ET (X>-0.001);
 FINFONC;
 
 CONTACT2;I;37;ENTIER;EXTRAC_DEMI2;1;

 DEFFONC RONDELLE(X,Y,Z);                                                                        
 RONDELLE = (X**2 + Y**2 >2.499**2) ET (Z< 3.499);FINFONC;
 
 FIXE;I;37;ENTIER;RONDELLE;1;
@;

