      DEFFONC PLAN4(X,Y,Z); { EXTRACTION DE L'ARC SUIVANT CRITERE }
              PLAN4 = (Z<=8.6);
      FINFONC;
      PLAN4;

{ *** DEFINITION DE L'ARC INTERSECTION D'UN TRONC DE CONE ET D'UN CYLINDRE *** }
