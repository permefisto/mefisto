{ DECLARATION DES VARIABLES                                           } 
{ =================================================================== }
DEFVAR NBRE;
NBRE = 3;
DEFVAR PI,RH;
PI = ATAN(1)*4;
RH = 3.5;  {RAYON DU CYLINDRE DU HAUT}

{LES 2 TRANSFORMATIONS CYLINDRE DU HAUT (X,Y,Z) <=> PLAN (X,Y,Z)}
DEFFONC TCPX(X,Y,Z); TCPX=RH * ASIN( Y/RH ); FINFONC;
DEFFONC TCPY(X,Y,Z); TCPY=Z;                 FINFONC;
DEFFONC TCPZ(X,Y,Z); TCPZ=0;                 FINFONC;

DEFFONC TPCX(X,Y,Z); TPCX=RH * COS( X/RH ); FINFONC;
DEFFONC TPCY(X,Y,Z); TPCY=RH * SIN( X/RH ); FINFONC;
DEFFONC TPCZ(X,Y,Z); TPCZ=Y;                FINFONC;

6; {LES TRANSFORMATIONS}
  CYLPLAN; 6;    {F:R3->R3 DEFINIE PAR 3 FONCTIONS (FI)}
           TCPX; {NOM FONCTION ABSCISSE X=F1(X,Y,Z)}
           TCPY; {NOM FONCTION ORDONNEE Y=F2(X,Y,Z)}
           TCPZ; {NOM FONCTION COTE     Z=F3(X,Y,Z)}
  PLANCYL; 6;    {F:R3->R3 DEFINIE PAR 3 FONCTIONS (FI)}
           TPCX; {NOM FONCTION ABSCISSE X=F1(X,Y,Z)}
           TPCY; {NOM FONCTION ORDONNEE Y=F2(X,Y,Z)}
           TPCZ; {NOM FONCTION COTE     Z=F3(X,Y,Z)}
@;
 
DEFVAR A2A3,A3A4,A4A6,A6A1,A5A6,A4B3,B3A6,A1B1,A1A2,A4A5,A5B2,A4B2,B2B3,B1B3,B1B2;
 A2A3 = 1.5*PI/2;
 A3A4 = 0.1;
 A4A6 = 2.5*SIN(ACOS(1.6/2.5));
 A4B3 = 3.5*SIN(ACOS(1.6/3.5));
 B3A6 = A4B3 - A4A6;
 A6A1 = 2.5*ASIN(1.6/2.5);
 A5A6 = 2.5*ACOS(1.6/2.5);
 A1B1 = 1;
 A1A2 = 1;
 A4A5 = 0.9;
 A5B2 = 1;
 A4B2 = A4A5 + A5B2;
 B2B3 = ACOS(1.6/3.5)*3.5;
 B1B3 = ASIN(1.6/3.5)*3.5;
 B1B2 = B2B3 + B1B3;

DEFVAR A1C1,A2C2,A6C6,A4C4,A5C5;
 A1C1 = 3.5;A2C2 = 3.5;A6C6 = 3.5;A4C4 = 3.5;A5C5 = 3.5;

DEFVAR C1E1,C2E2,C6E6,C4E4,C5E5,A2E2;
 C1E1 = 1.7;C2E2 = 1.7;C6E6 = 1.7;C4E4 = 1.7;C5E5 = 1.7;A2E2 = A2C2+C2E2;

DEFVAR F3L3,L3M6,E4G4,K4M4,G4K4,M6M4;
 F3L3 = 3.4;
 L3M6 = SQRT((3.5*SIN(ACOS(1.6/3.5))-2.5*SIN(ACOS(1.6/2.5)))**2+0.6**2);
 E4G4 = 0.6;
 K4M4 = 0.4;
 G4K4 = 1.5*PI;
 M6M4 = 2.5*SIN(ACOS(1.6/2.5));

DEFVAR F2H2,K7M5;
 F2H2 = 0.6;
 K7M5 = SQRT((3.2*SIN(ACOS(1.6/3.2))-2.5*SIN(ACOS(1.6/2.5)))**2+0.4**2);

DEFVAR L3J7,G4H2,E4F2,K4K7,M4M5,M5M6; 
 L3J7 = 3.5*ACOS(1.45/3.5);
 G4H2 = A4A5 + A5B2;
 E4F2 = A4A5 + A5B2;
 K4K7 = 1.6;
 M4M5 = A4A5;
 M5M6 = A5A6;

