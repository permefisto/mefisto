 { NOM de LIGNE }
 contour;
 { DANS LE LEXIQUE ~>LIGNE }
 { NOM de LIGNE }
 cercle;
 { DANS LE LEXIQUE ~>LIGNE }
 { NUPTIT(1..NBPTIT) 'nom des points internes futurs sommets' }
 { DISOSV(1..NBPTIT) 'distance souhaitee aux sommets voisins' reel ; }
 { NOM de la SURFACE ou ABANDON? }
 @;

 5;
 { OBJETS parties de l OBJET }
 { NOM de l'OBJET ou ABANDON? }
 obj;
 0;
 { classique 2D ou 3D }
 3;
 { NBDOBJ 'nombre des Points Lignes Surfaces Volumes Objets de l''objet' }
 { POINT ou LIGNE ou SURFACE ou VOLUME ou OBJET? }
 s; surf;
 { POINT ou LIGNE ou SURFACE ou VOLUME ou OBJET? }
 l; contour;
 { POINT ou LIGNE ou SURFACE ou VOLUME ou OBJET? }
 l; cercle;
 { NTYOBJ(1..NBDOBJ) 'nom du type PLSVO et nom du PLSVO' typeobjet ; }
 @;

