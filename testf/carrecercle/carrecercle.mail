DefVar nba; nba=5;
@;
1;
{ POINTS sommets de l objet }
           1;
{ FRAPPE des valeurs }
a; I; 1; 0; 0; 0;
{ DANS LE LEXIQUE ~>TRANSFO }
{ coordonnees x y z }
{ COORPO '3 coordonnees cartesiennes du point' xyz ; }
b; i; 1; 1; 0; 0;
c; i; 1; 1; 1; 0;
d; I; 1; 0; 1; 0;
centre; i; 1; 0.5; 0.5; 0;
ce1; i; 1; 0.7; 0.5; 0;
ce2; i; 1; 0.5; 0.7; 0;
@;
@;

2;
{ LIGNES aretes de l objet }
ab; i; 2; { segment de droite }
    nba; { NBARLI 'nombre d''aretes de la ligne' entier ; }
    1; { RAIGEO 'raison geometrique espacant les sommets' reel ; }
    a; { DANS LE LEXIQUE ~>POINT }
    b; { DANS LE LEXIQUE ~>POINT }
bc; i; 2; nba; 1; b; c;
cd; I; 2; nba; 1; c; d;
da; I; 2; nba; 1; d; a;
contour; i; 51; { union de plusieurs lignes }
    4; { NBLIUN 'nombre de lignes de l''union' entier ; }
   ab; bc; cd; da; { DANS LE LEXIQUE ~>LIGNE }
cercle; i;{ DANS LE LEXIQUE ~>TRANSFO }
 8;{ cercle complet }
 20;{ NBARLI 'nombre d''aretes de la ligne' entier ; }
 2;{ cercle defini par le centre, un point du cercle, un point du plan }
 CENTRE;{ DANS LE LEXIQUE ~>POINT }
 CE1;   { DANS LE LEXIQUE ~>POINT }
 CE2;   { DANS LE LEXIQUE ~>POINT }
@;

3;
 { SURFACES faces de l objet }
 { NOM de la SURFACE ou ABANDON? }
 surf; i;
 { DANS LE LEXIQUE ~>TRANSFO }
 9;
 { triangulation de lignes fermees par TE }
 0.1;
 { ARETMX 'taille max des aretes des triangles equilateraux' reel ; }
 2;
 { NBLFTR 'nombre de lignes fermees contour de la surface' entier ; }
 0;
