20; { PRECISION pour IDENTIFIER des POINTS }
 1; 0.001;   {Autour d'un POINT NON ORIGINE}
 2; 0.0005;  {Autour de l'ORIGINE}
@;

3; { SURFACES faces de l objet }
 bas; i; 1;  { quadrangle ALGEBRIQUE structure ou non }
 p1p2; p2p3; p3p4; p4p1; { DANS LE LEXIQUE ~>LIGNE }
 2;                      { maillage irregulier }
 gauche;   i; 1; p1p2; p2p6; p5p6; p1p5; 2;
 derriere; i; 1; p4p1; p4p8; p8p5; p1p5; 2;
 devant;   i; 1; p2p3; p3p7; p6p7; p2p6; 2;
 droite;   i; 1; p3p4; p4p8; p7p8; p3p7; 2;
 haut;     i; 1; p5p6; p6p7; p7p8; p8p5; 2;
 hexad; i; 51; 6; bas; gauche; derriere; devant; droite; haut;
@;

4; { VOLUMES parties de l objet }
 hexad8; i; 8;{ un volume ferme d un volume pour option 9 }
 1;        { NBSF1V nombre de surfaces fermees contour du volume }
 hexad;    { DANS LE LEXIQUE ~>SURFACE }

 hexad9; i; 9; { le volume union de volumes fermes de type 8 }
 50000;      { MXSOVO nombre maximal de sommets de la tetraedrisation }
 0.2;        { ARETGR longueur de l'arete de la grille reguliere } 
 3.0;        { ANTE2P degres du petit angle de coplanearite }
 0;          { NBPTIV nombre de points internes fournis par lutilisateur }
 1;          { NBVOPA nombre de volumes de type 8 de la partition }
 hexad8;     { DANS LE LEXIQUE ~>VOLUME } 

 hexada; i; 30; { amelioration d une tetraedrisation }
     hexad9;    { DANS LE LEXIQUE ~>VOLUME }
       0.33;    { QUTEMN qualite au dessous de laquelle ameliorer }
        3.0;    { ANTE2P degres du petit angle de coplanearite }
          5;    { NBITAT nombre des iterations pour ameliorer }
@;       
FERMER;

