 defvar  x1, y1, z1, r, x12, y12, z12, r2;
 x1=1;    x12=x1/2;
 y1=2;    y12=y1/2;
 z1=1.5;  z12=z1/2;
 r=1;     r2=r**2;

 deffonc taille_ideale(x,y,z);
    taille_ideale = 0.03 + 0.2 * 
       sqrt( abs( (x-x12)**2 + (y-y12)**2 + (z-z12)**2 - r2 ) );
 finfonc;

1; { POINTS sommets de l objet }
  1; { FRAPPE des valeurs }
