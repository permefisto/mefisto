C  
C     FICHIER DEPENDANT MACHINE : VERSION STANDARD ORDINATEUR A MOTS DE 32 BITS
C     FICHIER ~/incl/msvaau.inc
C
C     NMORCI : NOM DE L ORDINATEUR CIBLE   ICI MOT32BIT
C     NBTYPV : NOMBRE DE TYPES DE VARIABLES
C     KTYPES : NOM DES DIFFERENTS TYPES DE VARIABLES
C          LOGIQUE  => 1 CARACTERE=> 2  ENTIER/2 => 3 ENTIER   => 4
C          REEL     => 5 REEL2    => 6  REEL4    => 7 COMPLEXE => 8
C          COMPLEXE2=> 9 MOTS     => 10 ^LEXIQUE =>11 XYZ      =>12
C          TYPEOBJET=>13
C
C     NBCNFI : NOMBRE DE CARACTERES POUR DEFINIR LE NOM D UN FICHIER => 4
C     NBCHMO : NOMBRE DE CARACTERES PAR MOT => 4
C     NOTYPK : NUMERO DU TYPE CARACTERE     => 2
C     NOTYPI : NUMERO DU TYPE ENTIER        => 4
C
C     LES TABLEAUX INITIALISES PAR LE SP MSINIT DEPM
C     LE TABLEAU VAD1MO : NOMBRE DE VARIABLES DANS UN MOT MEMOIRE
C                         POUR CHAQUE TYPE DE VARIABLE
C     LE TABLEAU MOTSVA : NOMBRE DE MOTS D UNE VARIABLE SELON LE TYPE
C     LE TABLEAU MOTYPV : LE NOMBRE DE VARIABLES DANS UN MOT POUR I=1,3
C                         LE NOMBRE DE MOTS PAR VARIABLES    POUR I=4,12
C
      CHARACTER*8       NMORCI
      CHARACTER*9       KTYPES
      PARAMETER        (NBTYPV=13 , NBCNFI=4 , NBCHMO=4 , NOTYPK=2 ,
     %                  NOTYPI=4  , NMORCI='MOT32BIT' )
      COMMON / MSVACH / KTYPES(NBTYPV)
      COMMON / MSVAAU / VAD1MO(NBTYPV),MOTSVA(NBTYPV),MOTYPV(NBTYPV)
