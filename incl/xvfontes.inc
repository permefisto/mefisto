C
C ======================================
C FICHIER ~/incl/xvfontes.inc
C ======================================
C
C  CE COMMON CONTIENT LE NOMBRE, LE NOM ET LES CARACTERISTIQUES
C  DES FONTES DE CARACTERES DE X11 ET UTILISABLES DEPUIS FORTRAN  
C         
C     MAXFONTS FONTES AU PLUS SONT STOCKABLES
      PARAMETER   (MAXFONTS=512, MAXHPX=128)
C
C     NBFONT : NOMBRE DE FONTES DISPONIBLES  (<=MAXFONTS)
C     NOFONT : NUMERO DE LA FONTE ACTUELLEMENT CHARGEE
C     NPHFCO : HAUTEUR EN PIXELS D''UNE LIGNE DE MENU TRACMAIL
C                 POUR TENIR EN HAUTEUR DANS LA FENETRE DE TRACE
C     NPHFHI : HAUTEUR EN PIXELS D''UNE LIGNE DE MENU DE L''HISTORIQUE
C     NBCAFO : NOMBRE DE CARACTERES DU NOM DE CHACUNE DES FONTES
C     NUFOHPX : NUFOHPX( LHPX ) = NUMERO DE LA FONTE X11 DE HAUTEUR PIXEL LHPX
      INTEGER           NBFONT, NOFONT, NPHFCO, NPHFHI
      INTEGER           NBCAFO(0:MAXFONTS), NUFOHPX( MAXHPX )
      COMMON / XVFON  / NBFONT, NOFONT, NPHFCO, NPHFHI,
     %                      NBCAFO, NUFOHPX
C
      CHARACTER*256     NMFONT(0:MAXFONTS-1)
      COMMON / XVFONK / NMFONT
C     NMFONT : NOMS  DES NBFONT FONTES DISPONIBLES
