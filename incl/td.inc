C     FICHIER ~/incl/td.inc

C     ATTENTION En cas d'augmentation de NBTD, COMPILER
C     EXECUTER d'abord cblg_tout AVANT cbgpara ... SINON PROBLEMES...
C--------------------------------------------------------------------

C     LES TABLEAUX DE GESTION DES TABLEAUX DESCRIPTEURS TD
C     ****************************************************
      PARAMETER    (NBTD=64,MXLITD=512,L1IDEN=5,MXIDEN=256,
     %              L1PILE=6,MXPILE=64,MXTAS=256,MXTMS=16,
     %              NCKTD=96,NCLIGN=96,NCFICA=128,MXSUFX=16)

      CHARACTER*1  KSUFIX
      PARAMETER       (KSUFIX='"')
C     SEPARATEUR ENTRE LE NOM ET LE SUFFIXE

      CHARACTER*(NCKTD) KTD(MXLITD)
C     KTD    CONTIENT LES TABLEAUX DESCRIPTEURS EN MC

      CHARACTER*(NCLIGN) KLIGNE
C     KLIGNE EST UN BUFFER D'IMPRESSION D'UNE LIGNE
C     ATTENTION : NCKTD DOIT ETRE INFERIEUR OU EGAL A NCLIGN

      CHARACTER*(NCFICA) KFICA
C     KFICA EST UN BUFFER D'ENREGISTREMENT DU FICHIER CARACTERES
C     DE NUMERO D'UNITE LOGIQUE NFFICA

      CHARACTER*80  NOMTS(MXTMS)
C     NOM DES TABLEAUX TMS EN COURS DE TRAITEMENT
C     AU PLUS MXTMS TMS SIMULTANEMENT
C     LHTMS  LE NUMERO DU TMS EN COURS DE TRAITEMENT

      CHARACTER*(MXSUFX) KSUTMS(MXTMS)
C     L'EVENTUEL SUFFIXE A DECODER DU TABLEAU TMS

      INTEGER     NOTAMS(MXTMS)
C     NOTAMS(I) = NUMERO DU TABLEAU MS DE CE TMS I

      INTEGER     MNTAMS(MXTMS)
C     MNTAMS(I) = ADRESSE MCN DU TABLEAU MS DE CE TMS

      INTEGER     NBVATC(MXTMS)
C     NBVATC(I) = NOMBRE DE VARIABLES DU TABLEAU EN MC

      INTEGER     MCTAMS(MXTMS)
C     MCTAMS(I) = ADRESSE MN DU TABLEAU MC COPIE DU TABLEAU MS

      INTEGER     NOTADS(MXTMS)
C     NOTADS(I) = NUMERO DANS DICOTD DU TABLEAU DESCRIPTEUR DE
C                 CE TMS I

      INTEGER     LDTS(MXTMS)
C     LE DECALAGE DANS LE TABLEAU TS EN COURS DE TRAITEMENT

      INTEGER     NBVATA(MXTMS)
C     LE NOMBRE DE TMS D'UN TABLEAU DE TMS

      INTEGER     NBIDEN(MXTMS)
C     LE NOMBRE D'IDENTIFICATEURS DE CE TMS

      CHARACTER*48  DICOTD(NBTD)
C     DICOTD EST LA TABLE DES NOMS DES TD

      CHARACTER*8   KIDENT(MXIDEN)
C     KIDENT EST LA TABLE DES NOMS DES IDENTIFICATEURS

      INTEGER       IDENT(0:L1IDEN,MXIDEN)
C     IDENT         CONTIENT LES CARACTERISTIQUES DES NBIDEN IDENTIFICATEURS
C     NUIDEN        NUMERO DE L'ACTUEL IDENTIFICATEUR EN COURS DE TRAITEMENT
C     IDENT(0,I) = LHPILE LA HAUTEUR DANS LA PILE AU MOMENT OU
C                         L'IDENTIFICATEUR I EST RENCONTRE
C     IDENT(1,I) = TYPE DE L'IDENTIFICATEUR
C          LOGIQUE   => 1 CARACTERE=> 2  ENTIER/2 => 3 ENTIER   => 4
C          REEL      => 5 REEL2    => 6  REEL4    => 7 COMPLEXE => 8
C          COMPLEXE2 => 9 MOTS     => 10 ^LEXIQUE =>11 XYZ      =>12
c          TYPEOBJET =>13
C     IDENT(2,I) = SI TABLEAU POINTEUR SUR LETAS , 0 SINON
C     IDENT(3,I) = LDTS LE DECALAGE DANS LE TS POUR ATTEINDRE LE 1-ER
C                       MOT DE LA VARIABLE ASSOCIEE A L'IDENTIFICATEUR
C     IDENT(4,I) = NLI NO DE LIGNE   KTD DU PREMIER CARACTERE
C                      DE L'IDENTIFICATEUR I
C     IDENT(5,I) = NCI NO DE COLONNE KTD DU PREMIER CARACTERE
C                      DE L'IDENTIFICATEUR I

      INTEGER       LETAS(1:MXTAS)
C     LETAS = NOMBRE D'INDICES DU 1-ER  TABLEAU
C             VALEUR INFERIEURE VALEUR SUPERIEURE DU 1-ER  INDICE
C             VALEUR INFERIEURE VALEUR SUPERIEURE DU 2-EME INDICE
C             ...
C             NOMBRE D'INDICES DU 2-EME TABLEAU
C             ...

      INTEGER       LAPILE(0:L1PILE,MXPILE)
C     LAPILE DES CODES OPERATIONS
C     LAPILE(0,I) = LHTMS LE NUMERO DU TMS TRAITE
C     LAPILE(1,I) = CODE OPERATION :  1 TMS , 2 CAS

C     SI TMS
C     LAPILE(2,I) = NLD LIGNE DU PREMIER CARACTERE Du TMS
C     LAPILE(3,I) = NCD COLONNE PREMIER CARACTERE DE L'IDENT DU TMS
C     LAPILE(4,I) = NLR LIGNE   DE RETOUR AVANT DE DEPILER LE TMS
C     LAPILE(5,I) = NCR COLONNE DE RETOUR AVANT DE DEPILER LE TMS
C     LAPILE(6,I) = IMPRES PARAMETRE D'IMPRESSION OU MODIFICATION

C     SI CAS
C     LAPILE(2,I) = LDTS LE DECALAGE RELATIF AU DEBUT DU TMS
C                        EN DEBUT DE CAS
C     LAPILE(3,I) = IMPOSS IMPOSSIBILITE OU NON DE GENERER LES PARAMETER
C                          APRES UN TABLEAU DE TAILLE DYNAMIQUE
C     LAPILE(4,I) = NOIDEN NUMERO DE L'IDENTIFICATEUR DU CAS
C     LAPILE(5,I) = NBCAS  NOMBRE DE CAS INTERNES + 1
C     LAPILE(6,I) = IMPRES PARAMETRE D'IMPRESSION LORS DE L'ABORD DU CAS
C                   0 PAS DE MODIFICATION OU AFFICHAGE , 1 SINON
C-----------------------------------------------------------------------
      COMMON / KTDESC / KTD    , KLIGNE , KFICA  , DICOTD ,
     %                  KIDENT , NOMTS  , KSUTMS
      COMMON / ITDESC / IDENT  , LETAS  , LAPILE , LDTS   , NBVATA ,
     %                  NOTAMS , MNTAMS , NBVATC , MCTAMS ,
     %                  NOTADS , NBIDEN , NUIDEN ,
     %                  LHTAS  , LHPILE , LHKTD ,
     %                  IMPRES , NOMUET , LCLIGN , LCFICA , LHTMS
C-----------------------------------------------------------------------
