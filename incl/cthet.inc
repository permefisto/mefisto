      DOUBLE PRECISION   TEMPEL, TEMPELn, TEMPEL0
      DOUBLE PRECISION   ONDEPI, ONDEPIn, ONDEPI0
      INTEGER             MNTHET, MNTHETn, MNTHET0
      INTEGER             MNTHDL, MNTHDLn, MNTHDL0
      INTEGER             MNNODL, MNTIME, NBNOEMA, NBDLMXEF
      COMMON  / PBTHNL / TEMPEL, TEMPELn, TEMPEL0,
     %                   ONDEPI, ONDEPIn, ONDEPI0,
     %                   MNTHET, MNTHETn, MNTHET0,
     %                   MNTHDL, MNTHDLn, MNTHDL0,
     %                   MNNODL, MNTIME, NBNOEMA, NBDLMXEF, MONODL
C
C     CE COMMUN SERT EN THERMIQUE ou NLSE A STOCKER LES ADRESSES DES TABLEAUX
C     DE TEMPERATURES POUR PERMETTRE AUX SOUS-PROGRAMMES DE
C     CALCUL DES DONNEES CAPACITE, CONDUCTIVITE, SOURCE, ... , D'EN DISPOSER
C     ET PASSER LA VALEUR DE LA TEMPERATURE AU POINT DE TRAITEMENT ACTUEL
C     ET A RETROUVER LE TEMPS ACTUEL
C
C     TEMPEL : TEMPERATURE AU POINT OU PARTIE RELLE D'UNE ONDE COMPLEXE NLSE
C              AU TEMPS tn+1
C     TEMPELn: TEMPERATURE AU POINT OU PARTIE RELLE D'UNE ONDE COMPLEXE NLSE
C               AU TEMPS tn
C     TEMPEL0: TEMPERATURE AU POINT OU PARTIE RELLE D'UNE ONDE COMPLEXE NLSE
C               AU TEMPS t0
C
C     ONDEPI : PARTIE IMAGINAIRE D'UNE ONDE COMPLEXE NLSE AU TEMPS tn+1
C     ONDEPIn : PARTIE IMAGINAIRE D'UNE ONDE COMPLEXE NLSE AU TEMPS tn
C     ONDEPI0: PARTIE IMAGINAIRE D'UNE ONDE COMPLEXE NLSE AU TEMPS t0
C
C     MNTHET : ADRESSE MCN DU VECTEUR"TEMPERATURE AU TEMPS tn+1
C     MNTHETn: ADRESSE MCN DU VECTEUR"TEMPERATURE AU TEMPS tn
C     MNTHET0: ADRESSE MCN DU VECTEUR"TEMPERATURE AU TEMPS t0
C
C     MNTHDL :  ADRESSE MCN DE LA TEMPERATURE DES DL DE L'EF AU TEMPS tn+1
C     MNTHDLn: ADRESSE MCN DE LA TEMPERATURE DES DL DE L'EF  AU TEMPS tn
C     MNTHDL0:  ADRESSE MCN DE LA TEMPERATURE DES DL DE L'EF ACTUEL AU TEMPS t0
C
C     MNNODL : ADRESSE MCN DES NUMEROS DES DL DE L'EF ACTUEL
C      MONODL : NOMBRE DE VARIABLES RESERVEES POUR LE TABLEAU NODL

C     MNTIME : ADRESSE MCN -1 DU PREMIER TEMPS STOCKE 
C              DERRRIERE LES VECTEURS TEMPERATURE
C     MNTIME = MNVECT + WECTEU + NTDL * NBTEMP * MOREE2 -1
C               ADRESSE MCN -1 DES TEMPS
C     TEMPS = RMCN(MNTIME+NUMERO_VECTEUR_TEMPERATURE) NUMERO DE 1 A NBTEMP
C
C     NBNOEMA: NOMBRE DE NOEUDS DU MAILLAGE ou
C              NOMBRE DE DL DE LA PARTIE REELLE  (ET IMAGINAIRE) DE L'ONDE NLSE
C     NBNOEMA: NOMBRE DE NOEUDS DE L'EF ACTUEL
C
C     NBDLMXEF : NOMBRE MAXIMAL DE DL DE L'UN DES TYPES D'EF
C      SERT A DECLARER ET DETRUIRE LES TABLEAUX THDL, THDLn, THDL0
