C
C     FICHIER ~/incl/darete.inc 

      DOUBLE PRECISION  DARETE
      INTEGER                         NOFOTI
      COMMON / DEARET /  DARETE, NOFOTI
C
C     DARETE EST LA VALEUR PAR DEFAUT DES ARETES DU MAILLAGE
C     DARETE=0D0 INDIQUE UNE NON INITIALISATION DE CETTE VALEUR
C     SA VALEUR PEUT ETRE REMPLACEE DANS LES CALCULS PAR LA
C     VALEUR DE LA FONCTION 'TAILLE_IDEALE(X,Y,Z)' ou 'EDGE_LENGTH(X,Y,Z)'
C     AU POINT (X,Y,Z) SI ELLE A ETE FOURNIE PAR L'UTILISATEUR
C      SELON LE LANGAGE LU

C     NOFOTI>0  NUMERO DE LA FONCTION UTILISATEUR 'TAILLE_IDEALE(x,y,z)'
C                      ou 'EDGE_LENGTH(x,y,z)'
C          =0   PAS de DONNEE DE LA FONCTION UTILISATEUR 'TAILLE_IDEALE(x,y,z)'
C                     ou 'EDGE_LENGTH(x,y,z)'
