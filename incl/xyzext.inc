C
C     FICHIER ~/incl/xyzext.inc 

      REAL              COOEXT(6,2), XYZAMPLI(4)
      INTEGER           INIEXT, MOAXYZ
      COMMON / XYZEXT / COOEXT, XYZAMPLI, INIEXT, MOAXYZ

C     COOEXT(K,1) = MINIMUM DE LA COORDONNEE K
C     COOEXT(K,2) = MAXIMUM DE LA COORDONNEE K
C     INIEXT=0 SI COOEXT NON INITIALISE PAR UN PLSV (sert dans majext.f)
C           =1 SI COOEXT A ETE INITIALISE
C           =2 SI COOEXT A ETE MODIFIE DANS majext.f
C     MOAXYZ=0 SI COOEXT N''EST PAS AMPLIFIE
C           =1 SI COOEXT EST MODIFIE ET XYZAMPLI SONT ACTIFS
C     XYZAMPLI COEFFICIENTS D''AMPLIFICATION DES COORDONNEES X Y Z
C              PAR DEFAUT ILS VALENT 1 ET SONT INACTIFS
C              MOAXYZ=1: ILS SONT MODIFIES EN CAS DE TRACE 3D
C              AVEC DES ECHELLES TRES DIFFERENTES EN X Y Z
C              POUR OBTENIR UN TRACE SUFFISAMMENT LARGE
C              MANOEUVRABLE AVEC LA SOURIS ET SES 3 BOUTONS
C              Cf sp $MEFISTO/ther/tr1dtem.f
