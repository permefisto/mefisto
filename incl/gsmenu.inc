C
C     FICHIER ~/incl/gsmenu.inc
C
      PARAMETER   (NRDOCU=1,NRHIST=2,NRMENU=3,NRLGLU=4,
     %             NRINVI=5,NRLGSA=6,NRERR0=7,NRERR=8)
C
C     NRDOCU : NUMERO DU RECTANGLE DE DOCUMENTATION
C     NRHIST : NUMERO DU RECTANGLE DE L'HISTORIQUE
C     NRMENU : NUMERO DU RECTANGLE DU MENU
C     NRLGLU : NUMERO DU RECTANGLE DES LIGNES LUES
C     NRINVI : NUMERO DU RECTANGLE DE L'INVITE
C     NRLGSA : NUMERO DU RECTANGLE DE LA LIGNE DE SAISIE
C
      PARAMETER   (MXRECT=8 , INMENU=-123456789,
     %             NBCAME=96, MXLGME=64, NBCAHI=48, MXLGHI=16,
     %             NBCADO=96, MXLGDO=40, NBCAIN=96, MXLGIN= 2,
     %             NBCALG=96, MXLGSA=1 , NBCAER=96, MXLGER=32,
     %             NBCALS=NBCALG+10 )
C
C     MXRECT : NOMBRE MAXIMAL DE RECTANGLES
C     INMENU : VALEUR PAR DEFAUT ASSOCIEE A CHAQUE LIGNE D'UN MENU
C     NBCAME : NOMBRE DE CARACTERES D'UNE LIGNE DU MENU
C     MXLGME : NOMBRE MAXIMAL DE LIGNES DU MENU
C     NBCAHI : NOMBRE DE CARACTERES D'UNE LIGNE DE L'HISTORIQUE
C     MXLGHI : NOMBRE MAXIMAL DE LIGNES DE L'HISTORIQUE
C     NBCADO : NOMBRE DE CARACTERES D'UNE LIGNE DE LA DOCUMENTATION
C     MXLGDO : NOMBRE MAXIMAL DE LIGNES DE LA DOCUMENTATION
C     NBCAIN : NOMBRE DE CARACTERES D'UNE LIGNE DE L'INVITE
C     MXLGIN : NOMBRE MAXIMAL DE LIGNES DE L'INVITE
C     NBCALG : NOMBRE DE CARACTERES D'UNE LIGNE DE SAISIE = CELUI DE KLG
C     MXLGSA : NOMBRE MAXIMAL DE LIGNES DE LA LIGNE DE SAISIE
C     NBCAER : NOMBRE DE CARACTERES D'UNE LIGNE DES ERREURS
C     MXLGER : NOMBRE MAXIMAL DE LIGNES DES ERREURS
C
      INTEGER      ECARRC,
     %             XRECT (MXRECT),YRECT (MXRECT),
     %             DXRECT(MXRECT),DYRECT(MXRECT),
     %             DXKARC(MXRECT),DYKARC(MXRECT),
     %             ECARLR(MXRECT),DYLGRC(MXRECT)
C
C     ECARRC        : ECART EN PIXELS ENTRE 2 RECTANGLES VOISINS
C     XRECT ,YRECT  : COORDONNEES PIXELS DU COIN SUPERIEUR GAUCHE DU RECTANGLE
C     DXRECT,DYRECT : LARGEUR ET HAUTEUR EN PIXELS DU RECTANGLE
C     DXKARC,DYKARC : LARGEUR ET HAUTEUR EN PIXELS D'UN CARACTERE
C     ECARLR        : ECARTEMENT PIXELS ENTRE LE CARACTERE ET LA LIGNE
C     DYLGRC        : HAUTEUR PIXELS D'UNE LIGNE DE CARACTERES
C
      INTEGER      NOIBLA,MNMTCL,
     %             NFRECT(MXRECT),NBRECT(MXRECT),
     %             NKRECT(MXRECT),NPRECT(MXRECT),
     %             MXLGRC(MXRECT),NBLGRC(MXRECT),
     %             MDLGRC(MXRECT),MDRECT(MXRECT)
C
C     NOIBLA : 1:ECRAN NOIR ET BLANC  0:SI COULEURS
C     MNMTCL : ADRESSE MCN DU TABLEAU DES RESULTATS DE LIMTCL
C     NFRECT : NUMERO DE LA COULEUR DU FOND DU RECTANGLE ET DES CARACTERES
C     NBRECT : NUMERO DE LA COULEUR DU BORD DU RECTANGLE
C     NKRECT : NUMERO DE LA COULEUR DES CARACTERES DU RECTANGLE
C     NPRECT : NUMERO DE LA POLICE  DES CARACTERES DU RECTANGLE
C     MXLGRC : NOMBRE MAXIMAL DE LIGNES DE CARACTERES DU RECTANGLE
C     NBLGRC : NOMBRE ACTUEL  DE LIGNES DE CARACTERES DU RECTANGLE
C     MDLGRC : NUMERO DU DERNIER CARACTERE NON BLANC DE LA DERNIERE LIGNE
C     MDRECT : NUMERO DU DERNIER CARACTERE NON BLANC DES LIGNES DU RECTANGLE
C
      CHARACTER*(NBCAME) KMENU(MXLGME)
      CHARACTER*(NBCAHI) KHIST(MXLGHI)
      CHARACTER*(NBCADO) KDOCU(MXLGDO)
      CHARACTER*(NBCAIN) KINVI(MXLGIN)
      CHARACTER*(NBCALS) KLGSA(MXLGSA)
      CHARACTER*(NBCAER) KERR (MXLGER)
C
C     KMENU : LES LIGNES DE CARACTERES DU MENU
C     KHIST : LES LIGNES DE CARACTERES DE L'HISTORIQUE
C     KDOCU : LES LIGNES DE CARACTERES DE LA DOCUMENTATION
C     KINVI : LES LIGNES DE CARACTERES DE L'INVITE
C     KLGSA : LES LIGNES DE CARACTERES DE LA LIGNE DE SAISIE DU CLAVIER
C     KERR  : LES LIGNES D'ERREURS DETECTEES
C
      INTEGER            NAMENU(MXLGME)
C
C     NAMENU : NUMERO ASSOCIE A CHAQUE LIGNE DU MENU (INMENU PAR DEFAUT)
C
      COMMON / GNMENU / NOIBLA,MNMTCL,
     %                  NFRECT,NBRECT,NKRECT,NPRECT,
     %                  MXLGRC,NBLGRC,MDLGRC,MDRECT,
     %                  NAMENU,ECARRC,
     %                  XRECT ,YRECT ,DXRECT,DYRECT,
     %                  DXKARC,DYKARC,ECARLR,DYLGRC
      COMMON / GKMENU / KMENU,KHIST,KDOCU,KINVI,KLGSA,KERR 

