SUBROUTINE CONVECBF( tn, tn1, NDIM,  NBSOM,  XYZSOM, &
                     NBNOEF, NBELEM, NUNOEF, NU1EFN, &
                     MOARET, MXARET, MNLARE, &
                     MOFACE, MXFACE, MNLFAC, &
                     NDDLNO, NTDLHB, VXYZPN0, VITMAX0, &
                     NBNOVI, VITCON, IERR )
! ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
! BUT : CALCUL DE LA VITESSE ui(tn,X(tn;tn+1,NOSOMT)) CONVECTEE EN TOUS
! ----- LES SOMMETS DU MAILLAGE DE TRIANGLES ou TETRAEDRES BREZZI-FORTIN
!       PAR REMONTEE DE LA CARACTERISTIQUE en chaque SOMMET sur UN TEMPS DT
!       PROBLEME de NAVIER STOKES sur des EF TAYLOR HOOD
!       INTEGRATION RETROGRADE DES CARACTERISTIQUES cf O. PIRONNEAU
!       POLYNOME P1-LAGRANGE + FONCTION BULLE POUR LA VITESSE
!       POLYNOME LAGRANGE DE DEGRE 1 POUR LA PRESSION
!       TRIANGLE ELEMENT FINI: e ref -> e EST P1 POUR CHAQUE COORDONNEE

! ATTENTION: LES VITESSES CONVECTEES AUX BARYCENTRES DES EF NE SONT PAS CALCULEES

! ENTREES:
! --------
! tn, tn1: INTERVALLE DE TEMPS tn tn+1  => DT PAS du TEMPS = tn1-tn
! DT     : LE PAS DE TEMPS ENTRE tn ET tn+1
! NBSOM  : NOMBRE DE SOMMETS DU MAILLAGE
! XYZSOM : 3 COORDONNEES DES SOMMETS ET MILIEUX DES ARETES DES EF
! NBNOEF : NOMBRE DE SOMMETS D'UN TRIANGLE = 6 et TETRAEDRE = 10
! NBELEM : NOMBRE DE TETRAEDRES DU MAILLAGE
! NUNOEF : NUMERO DES 3 ou 4 SOMMETS DES EF DU MAILLAGE
! NU1EFN : NUMERO D'UN EF CONTENANT LE SOMMET

! MOFACE : NOMBRE DE MOTS DE CHAQUE FACE DU TABLEAU LFACES
! MXFACE : NOMBRE MAXIMAL D'FACES DU TABLEAU LFACES
! MNLFAC : ADRESSE MCN DU TABLEAU LFACES cf hachag.f

! NDDLNO : TABLEAU DES POINTEURS SUR LE DERNIER DL DE CHAQUE SOMMET FLUIDE
!          CE TABLEAU EST DIMENSIONNE A 1+NBNOEU
! NTDLHB : NOMBRE TOTAL DE DEGRES DE LIBERTE DE L'OBJET HORS BARYCENTRES
! VXYZPN0: VECTEUR GLOBAL des DL VITESSES-PRESSIONS (1:NTDLHB) au TEMPS tn
!          SUIVI DES NDIM VITESSES AU BARYCENTRE DES TETRAEDRES
! VITMAX0: NORME DE LA VITESSE MAXIMALE DE VXYZPN0 AUX SOMMETS
! NBNOVI : NOMBRE DE NOEUDS VITESSE = SOMMETS + BARYCENTRE DES EF BF
!
! SORTIES:
! --------
! VITCON : VITESSE CONVECTEE de DT aux SOMMETS  ui(tn,X(tn;tn+1,NOSOMT))
! IERR   : CODE D'ERREUR 0 PAS D'ERREUR, >0 SINON
!+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
! AUTEUR : ALAIN PERRONNET LJLL UPMC & St Pierre du Perray Decembre 2012
!23456---------------------------------------------------------------012
!$ USE OMP_LIB
      IMPLICIT NONE
      include"./incl/threads.inc"
      REAL               tn, tn1, DT, XYZSOM(3,NBSOM)
      INTEGER            NDIM,   NBSOM, NBNOEF, NBELEM, NTDLHB, &
                         MOARET, MXARET, MNLARE, &
                         MOFACE, MXFACE, MNLFAC, &
                         NUNOEF(NBELEM,NBNOEF), NDDLNO(0:NBSOM), &
                         NU1EFN(NBSOM), IERR, NBNOVI
      DOUBLE PRECISION   VXYZPN0(1:*), VITMAX0, VITCON(NBNOVI,NDIM)

      DOUBLE PRECISION   V(3)
      INTEGER            NOSOMT

!$OMP PARALLEL DEFAULT(SHARED) PRIVATE(NOSOMT,V)

!     PAS DE TEMPS ENTRE tn et tn+1
      DT = tn1 - tn

      IF( NDIM .EQ. 2 ) THEN

!        TRIANGLES BREZZI-FORTIN
!$OMP DO SCHEDULE( STATIC, NBSOM/NBTHREADS )
         DO NOSOMT = 1, NBSOM

!           VITESSE CONVECTEE DU SOMMET NOSOMT
            CALL CONVECBF2( NOSOMT,  NU1EFN(NOSOMT), NBELEM, NUNOEF, &
                            MOARET,  MXARET, MNLARE, DT, XYZSOM, NDDLNO, &
                            NTDLHB,  VXYZPN0, VITMAX0, &
                            V,       IERR )
            VITCON(NOSOMT,1) = V(1)
            VITCON(NOSOMT,2) = V(2)

         ENDDO
!$OMP END DO

      ELSE

!        TETRAEDRES BREZZI-FORTIN
!$OMP DO SCHEDULE( STATIC, NBSOM/NBTHREADS )
         DO NOSOMT = 1, NBSOM

!           VITESSE CONVECTEE DU SOMMET NOSOMT
            CALL CONVECBF3( NOSOMT,  NU1EFN(NOSOMT), NBELEM, NUNOEF, &
                            MOFACE,  MXFACE, MNLFAC, DT, XYZSOM, NDDLNO, &
                            NTDLHB,  VXYZPN0, VITMAX0, &
                            V,       IERR )
            VITCON(NOSOMT,1) = V(1)
            VITCON(NOSOMT,2) = V(2)
            VITCON(NOSOMT,3) = V(3)

         ENDDO
!$OMP END DO
      ENDIF
!$OMP END PARALLEL

!!!      call affvect( 'convecbf.f: VITESSEx',     20,     VITCON )
!!!      call afl1ve(  'convecbf.f: VITESSE ', NBSOM*NDIM, VITCON )

      RETURN
END SUBROUTINE CONVECBF
