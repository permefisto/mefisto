tracecad { % then trace d'un cadre
  gsave zoomxmin epcadre sub zoomymin epcadre sub
  zoomxmax epcadre add zoomymax epcadre add cadrepath clip
  zoomxmin epcadre 2 div sub zoomymin epcadre 2 div sub
  zoomxmax epcadre 2 div add zoomymax epcadre 2 div add cadrepath
  epcadre setlinewidth str@k grestore
} if
tracelog { % then trace du logo
  gsave /taille 45 reduclog mul def /ZapfChancery-MediumItalic findfont taille scalefont setfont
  /tailbl taille 16 div def /larlog (Me\256sto) stringwidth pop tailbl 6 mul add def
  /haulog taille tailbl 3 mul add def
  /rays{ gsave larlog 2 div haulog neg translate
    newpath 121 {larlog 2 mul 0 moveto 0 0 lineto 0.5 rotate larlog 2 mul 0 lineto closepath
    fill 0 0  moveto 1.0 rotate } repeat grestore
  } bind def
  zoomxmax zoomxmin add larlog sub 2 div zoomxmax zoomxmin sub larlog sub 2 div xpolog mul add
  zoomymax zoomymin add haulog add 2 div zoomymax zoomymin sub haulog sub 2 div ypolog mul add
  translate 0 0 moveto larlog haulog neg 0 exch 0 exch 2 copy neg 6 2 roll
  rlineto rlineto rlineto closepath gsave fondcou {0}{1} ifelse setgray fill grestore
  1 reduclog mul setlinewidth fondcou {1}{0} ifelse setgray stroke
  tailbl 2 mul taille 0.75 mul tailbl add neg translate 0 0 moveto
  gsave (Me\256sto) true charpath clip rays grestore gsave (Me) stringwidth pop 0 rmoveto
  (e) stringwidth pop (\302) stringwidth pop add 2 div neg 0 rmoveto
  (\302) true charpath clip rays grestore grestore
} if
