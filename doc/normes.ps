%%BeginDocument: ../../MACRO/logo.eps

%=======================================================================================
% A NE PAS CHANGER
%=======================================================================================
  mark
  /tex where { pop /texval true def }{ /texval false def } ifelse
  /texdvips where { pop /texdvipsval true def /texval true def }
                  { /texdvipsval false def } ifelse
  /ptcm  28.3464566929134 def /cm {ptcm mul} def
%=======================================================================================
% OPTIONS UTILISATEURS
%=======================================================================================
% OPTION COULEUR
%=======================================================================================
                            % trace couleur (true) ou n&b = palette gris (false)
true   /couleur  exch def   % remis systematiquement a true si le fichier est envoye sur
                            % une imprimante couleur referencee (cf. Options Imprim.)

                            % couleur de fond : true = noir false = blanc
false  /fondcou  exch def   % remis systematiquement a false si couleur = false
                            % sauf si imprimante couleur referencee

% RECADRAGE
%=======================================================================================
    0  /zoomxmin exch def   % 
 1216  /zoomxmax exch def   % definition du rectangle de zoom choisi
    0  /zoomymin exch def   % a utiliser pour recadrer la figure
  960  /zoomymax exch def   %

                            % encadrement automatique des zones de trace
false  /autoreca exch def   % taper dans le fichier autoreca pour definir la limite
                            % entre deux zones a encadrer

% OPTIONS DE TRACE
%=======================================================================================
                            % largeur du trait de trace ]0,+oo[, 1 etant la norme.
   -1  /lartrait exch def   % le code -1 (valeur par defaut) permet de conserver la meme
                            %   largeur de trait et d'ecriture quelque soit le zoom.

                            % option de trace que maillage         : 0
    0  /tracemen exch def   %                 avec legende qualite : 1
                            %                 avec menus           : 2
                            % par defaut : si il y a un menu 2
                            %              sinon : si qualite 1, 0 sinon

                            % option de trace des facettes 0 fil de fer
    2  /tracecou exch def   %                              1 faces blanches
                            %                              2 faces de couleur

 true  /traceecr exch def   % option de trace des chaines de caracteres

% OPTIONS DE MISE EN PAGE
%=======================================================================================
 false  /tracecad exch def  % trace d'un cadre true ou false
                            % 
    4  /epcadre  exch def   % epaisseur du cadre

 false  /tracelog exch def  % trace du logo Mefisto : par defaut false si menu true sinon
    1  /xpolog   exch def   % position horizontale du logo Mefisto -1 gauche 1 droite
   -1  /ypolog   exch def   % position verticale   du logo Mefisto -1 bas    1 haut
                            % position par defaut 1 -1 coin bas droit

% OPTIONS DEPENDANTES DE L'IMPRIMANTE
%=======================================================================================
texval not {
  27.0 cm  /vsize exch def  % hauteur max de la zone de trace sur A4 < 29.7cm
  19.0 cm  /hsize exch def  % largeur max de la zone de trace sur A4 < 21.0cm
} if

version (2010.113) eq { % palette grise pour LaserWriter II (salle apollo)
  0.0  /gsefo    exch def   % niveau du gris le plus fonce pour segment 0 = noir
  0.8  /gsecl    exch def   %                        clair              1 = blanc
  0.1  /gfafo    exch def   % niveau du gris le plus fonce pour faces   0 = noir
  1.0  /gfacl    exch def   %                        clair              1 = blanc
}{
version (2011.110) eq { % palette grise pour LaserJet4 (salle HP)
  0.1  /gsefo    exch def   % niveau du gris le plus fonce pour segment 0 = noir
  0.9  /gsecl    exch def   %                        clair              1 = blanc
  0.5  /gfafo    exch def   % niveau du gris le plus fonce pour faces   0 = noir
  1.0  /gfacl    exch def   %                        clair              1 = blanc
}{
version (xxxx.xxx) eq { % palette grise pour LaserWriterII (salle Mac)
  0.1  /gsefo    exch def   % niveau du gris le plus fonce pour segment 0 = noir
  0.9  /gsecl    exch def   %                        clair              1 = blanc
  0.5  /gfafo    exch def   % niveau du gris le plus fonce pour faces   0 = noir
  1.0  /gfacl    exch def   %                        clair              1 = blanc
}{
version (2013.104) eq { % couleur pour jet d'encre couleur
  /couleur true def
}{                      % palette grise par defaut
  0.0  /gsefo    exch def   % niveau du gris le plus fonce pour segment 0 = noir
  0.9  /gsecl    exch def   %                        clair              1 = blanc
  0.5  /gfafo    exch def   % niveau du gris le plus fonce pour faces   0 = noir
  1.0  /gfacl    exch def   %                        clair              1 = blanc
} ifelse } ifelse } ifelse } ifelse

% OPTION FONTES
%=======================================================================================
                               % fontes par defaut (a mettre sous la forme par ex
/Courier      /fontm0 exch def %   de /Courier-BoldItalic /Helvetica ...)
/Helvetica    /fontp0 exch def % * /fontm0 est la fonte monospaced
                               % * /fontp0 est la fonte proportional

                               %   de /Courier-BoldItalic /Helvetica ...)

false         /bavard exch def % bavard a true indique les chaines de caracteres
                               %   ou la police choisie n'existe pas

%=======================================================================================

autoreca{ % definition des macros servant a l'auto-encadrement
  /nbrcad 0 def
  /c@rli {currentlinewidth} def
  /initcad{/nbrcad nbrcad 1 add def /xmin{dup}def /ymin{dup}def /xmax{dup}def /ymax{dup}def}def
  initcad
  /t@stxy{2 copy 2 copy /n c@rli 2 div def
    n sub dup ymin le{/ymin exch def}{pop}ifelse n sub dup xmin le{/xmin exch def}{pop}ifelse
    n add dup ymax ge{/ymax exch def}{pop}ifelse n add dup xmax ge{/xmax exch def}{pop}ifelse}def
  /t@stx@{2 copy dup ymin le{/ymin exch def}{pop}ifelse dup xmin le{/xmin exch def}{pop}ifelse
                 dup ymax ge{/ymax exch def}{pop}ifelse dup xmax ge{/xmax exch def}{pop}ifelse}def
  /m@veto {t@stxy moveto}def
  /m@v@to {2 copy t@stx@ moveto}def
  /m@v@t@ {2 copy 2 copy 2 copy tfont add t@stx@ t@stx@ moveto}def
  /sh@w   {3 2 roll dup show stringwidth 3 2 roll add 3 1 roll add exch t@stx@}def
  /l@neto {t@stxy lineto}def
  /l@n@to {2 copy t@stx@ lineto}def
  /rl@neto{2 copy currentpoint 3 2 roll add 3 1 roll add exch t@stxy pop pop rlineto}def
  /rl@n@to{2 copy currentpoint 3 2 roll add 3 1 roll add exch t@stx@ rlineto}def
  /t@stel{6 copy /ycent exch def /xcent exch def /hautel exch def /largel exch def
    2 copy exch dup truncate 0 ge{90 idiv 1 add}{90 idiv}ifelse
    exch dup truncate 0 ge{90 idiv}{90 idiv 1 sub}ifelse
    2 copy exch sub 1 add  3 1 roll 1 exch {90 mul exch} for
    2 add {dup cos largel mul xcent add exch sin hautel mul ycent add t@stxy pop pop} repeat}def
  /t@st@l{6 copy /ycent exch def /xcent exch def /hautel exch def /largel exch def
    2 copy exch dup truncate 0 ge{90 idiv 1 add}{90 idiv}ifelse
    exch dup truncate 0 ge{90 idiv}{90 idiv 1 sub}ifelse
    2 copy exch sub 1 add  3 1 roll 1 exch {90 mul exch} for
    2 add {dup cos largel mul xcent add exch sin hautel mul ycent add t@stx@} repeat}def
  /autoreca{xmin xmax ymin ymax initcad}def
  /encadre {xmin xmax ymin ymax 1 epais
    /font0 /Courier-Bold findfont [15 0 0 17 0 0] makefont definefont pop
    lartrait -1 eq {/font0 /font0 findfont reduc scalefont definefont pop} if
    /taillefonte{ dup /tfont exch 17 div 14 mul reduc mul def 14.0 div /font0 findfont exch scalefont setfont } bind def
    17 taillefonte /hsi (1234567890) stringwidth pop def
    /tab {hsi 0 rmoveto dup stringwidth pop neg 0 rmoveto show} def
    /hsize hsi 4 mul (1 : ) stringwidth pop add def
    /vsize tfont nbrcad 1 add mul 1.2 mul def /angle 0 def
    texval {
      /xorig zoomxmin tracecad{epcadre sub}if def /yorig zoomymin tracecad{epcadre sub}if def
      /cadrepath{newpath
      xorig yorig vsize sub moveto zoomxmax tracecad{epcadre add}if yorig vsize sub lineto
      zoomxmax tracecad{epcadre add}if zoomymax tracecad{epcadre add}if lineto
      xorig zoomymax tracecad{epcadre add}if lineto
      closepath} def cadrepath clip
    }{ nbrcad 4 mul copy
      /xxmin{dup}def /yymin{dup}def /xxmax{dup}def /yymax{dup}def
      /t@stx@{ dup yymax ge{/yymax exch def}{pop}ifelse dup yymin le{/yymin exch def}{pop}ifelse
               dup xxmax ge{/xxmax exch def}{pop}ifelse dup xxmin le{/xxmin exch def}{pop}ifelse}def
      nbrcad { t@stx@ } repeat 14 taillefonte
      /xxmin xxmin tfont 1.2 mul sub def /xxmax xxmax tfont 1.2 mul add def
      /yymin yymin tfont 1.2 mul sub def /yymax yymax tfont 1.2 mul add def
      yymin zoomymin sub dup vsize ge {/yorig zoomymin vsize add def /xorig zoomxmin def pop}
      {zoomymax yymax sub dup vsize ge {/yorig zoomymax def /xorig zoomxmin def pop pop}
      {xxmin zoomxmin sub dup vsize ge {/angle 90 def /xorig zoomxmin def /yorig zoomymin def pop pop pop}
      {zoomxmax xxmax sub dup vsize ge {/angle 90 def /xorig zoomxmax vsize sub def
                                        /yorig zoomymax hsize sub def pop pop pop pop}
      {/angle 90 def /xorig zoomxmax vsize sub def /yorig zoomymax hsize sub def
      2 copy ge {pop /xorig zoomxmin def /yorig zoomymin def}{exch pop} ifelse
      2 copy ge {pop /angle 0 def /yorig zoomymax def /xorig zoomxmin def}{exch pop} ifelse
      ge {/angle 0 def /yorig zoomymin vsize add def /xorig zoomxmin def}if}ifelse}ifelse}ifelse}ifelse
      gsave xorig yorig moveto angle rotate hsize 0 rlineto 0 vsize neg rlineto hsize neg 0 rlineto closepath
      1.0 setgray fill grestore
    } ifelse
    /sh@w {gsave tfont -0.1 mul dup rmoveto dup stringwidth pop tfont 0.2 mul add dup 0 rlineto
    0 tfont 1.2 mul rlineto neg 0 rlineto closepath 1.0 setgray fill grestore show}def
    nbrcad -1 1{5 1 roll
    /ymax exch 10 mul round 10 div def /ymin exch 10 mul round 10 div def
    /xmax exch 10 mul round 10 div def /xmin exch 10 mul round 10 div def
    newpath
    xmin c@rli 2 div sub ymin c@rli 2 div sub moveto xmax c@rli 2 div add ymin c@rli 2 div sub lineto
    xmax c@rli 2 div add ymax c@rli 2 div add lineto xmin c@rli 2 div sub ymax c@rli 2 div add lineto
    closepath stroke
    20 taillefonte xmin ymax moveto tfont dup 0.1 mul exch -1.1 mul rmoveto
    /st 2 string def dup st cvs sh@w 14 taillefonte
    gsave xmin c@rli sub ymin c@rli sub moveto
    tfont dup 0.1 mul exch -1.1 mul rmoveto /st 10 string def xmin st cvs sh@w grestore
    gsave xmin c@rli sub ymin c@rli sub translate 90 rotate
    tfont dup 0.1 mul exch 0.1 mul moveto /st 10 string def ymin st cvs sh@w grestore
    gsave xmax c@rli add ymax c@rli add moveto
    /st 10 string def xmax st cvs dup stringwidth pop neg tfont 0.1 mul sub tfont 0.1 mul rmoveto
    sh@w grestore
    gsave xmax c@rli add ymax c@rli add translate 90 rotate
    /st 10 string def ymax st cvs dup stringwidth pop neg tfont 0.1 mul sub tfont -1.1 mul moveto
    sh@w grestore 17 taillefonte
    gsave xorig yorig moveto angle rotate dup 1 add tfont mul -1.2 mul 0 exch rmoveto
    st cvs show ( : ) show xmin st cvs tab xmax st cvs tab ymin st cvs tab ymax st cvs tab grestore
    } for
    gsave xorig yorig moveto angle rotate 0 tfont -1.2 mul rmoveto
    (1 : ) stringwidth rmoveto (xmin) tab (xmax) tab (ymin) tab (ymax) tab
  } def
}{ % macros strandard
  /m@veto {moveto}  bind def /m@v@to  {moveto}  bind def /m@v@t@ {moveto}  bind def
  /sh@w   {show}    bind def /l@neto  {lineto}  bind def /l@n@to {lineto}  bind def
  /rl@neto{rlineto} bind def /rl@n@to {rlineto} bind def /t@stel { }       def
  /t@st@l { }       def      /autoreca{ }       def      /encadre{ }       def
} ifelse
lartrait 0 eq{ /str@k { } def }{ /str@k { stroke } bind def } ifelse
couleur not { /fondcou false def } if 
fondcou {
  /s@tc@u { setrgbcolor } bind def
  /s@tcou { setrgbcolor } bind def
  /setc@u { setrgbcolor } bind def
}{
  /s@tc@u { % inversion du blanc en noir et blanc en noir
    3 copy add add dup 0 eq { pop pop pop pop 1.0 1.0 1.0 }
                            { 3 eq { pop pop pop 0.0 0.0 0.0 } if } ifelse
    setrgbcolor
  } bind def
  /s@tcou { % inversion du noir en blanc
    3 copy add add 0 eq { pop pop pop 1.0 1.0 1.0 } if
    setrgbcolor
  } bind def
  /setc@u { % inversion du blanc en noir (pour T)
    3 copy add add 3 eq { pop pop pop 0.0 0.0 0.0 } if
    setrgbcolor
  } bind def
} ifelse
couleur { % couleur
/setcose{ pop s@tc@u } bind def
/setcofa{ pop s@tc@u } bind def
}{ % Noir&Blanc : palette de gris
/setcose{
  dup 1 exch sub gsefo mul exch gsecl mul add setgray pop pop pop
} bind def
/setcofa{
  dup 1 exch sub gfafo mul exch gfacl mul add setgray pop pop pop
} bind def
} ifelse
/S{ % trace d'une suite de segments couleurs pile : xn yn .. x0 y0 n coul
  gsave setcose newpath 3 1 roll m@veto { l@neto } repeat str@k grestore
} bind def
/FP{ % facette et polygone pile : xn yn .. x1 y1 n coul_pol coul_fac
  gsave setcofa  5 -1 roll dup 6 1 roll 2 mul 5 add 4 roll
  newpath 3 1 roll m@veto 1 sub { l@neto } repeat closepath
  gsave tracecou dup 0 ne { 1 eq { 1 setgray } if fill }{ pop } ifelse grestore
  setcose str@k grestore
} bind def
/typet{ % type de trait (continu tirete 1 ou 2
  [[] [4 4] [4 4]] exch get 0 setdash
} bind def
/cadrepath{ % definition du cadre de trace  pile : xmin ymin xmax ymax
  newpath 4 copy moveto 3 1 roll exch lineto 4 2 roll lineto lineto closepath
} bind def


texval not {  % orientation du dessin sur A4
  21.0 cm 2 div 29.7 cm 2 div translate
  vsize hsize gt {
    zoomxmax zoomxmin sub zoomymax zoomymin sub gt {
      90 rotate vsize hsize /vsize exch def /hsize exch def } if
  }{
    zoomxmax zoomxmin sub zoomymax zoomymin sub lt {
      90 rotate vsize hsize /vsize exch def /hsize exch def } if
  } ifelse
} if 
/reduc % calcul du coeff de reduction du a un eventuel zoom
  vsize zoomymax zoomymin sub div hsize zoomxmax zoomxmin sub div ge {
    zoomxmax zoomxmin sub  1216 div
    vsize   960 div hsize  1216 div 2 copy le { div mul }{pop pop} ifelse
  }{
    zoomymax zoomymin sub   960 div
    hsize  1216 div vsize   960 div 2 copy le { div mul }{pop pop} ifelse
  } ifelse
def
lartrait -1 eq {
  /reduclog reduc def
  texval { /reduc reduc reductex mul def } if
}{
 /reduclog reduc texval {reductex mul} if def /reduc lartrait def
} ifelse
/epcadre epcadre reduc mul def
texval not
{ % sortie directe sur imprimante
  vsize zoomymax zoomymin sub epcadre 2 mul add div hsize zoomxmax zoomxmin sub epcadre 2 mul add div
  2 copy gt { exch } if pop dup scale
  zoomxmin zoomxmax add 2 div neg zoomymin zoomymax add 2 div neg translate
}
{ % integration sur TeX
  /bavard false def
  texdvipsval
  { % integration par DVIPS et DVI2PS
    -1 -1 scale
    zoomxmax neg tracecad {epcadre sub} if zoomymin neg tracecad {epcadre add} if translate
  }
  { % integration par TEXTURES
    zoomxmin neg tracecad {epcadre add} if zoomymin neg tracecad {epcadre add} if translate
  }
  ifelse
}
ifelse
gsave
zoomxmin zoomymin zoomxmax zoomymax cadrepath clip newpath
/charge { % Chargement d'une fonte. pile : /police /corps (/ si normal) /style (/ si roman) haut larg (.) (mono ou prop)
  /mat [10 0 0 10 0 0] def /mats [10 0 0 10 0 0] def 6 3 roll
  /g@t {getinterval} bind def /p@t {putinterval} bind def
  /sty exch 20 string cvs def /cor exch 20 string cvs def /pol exch 30 string cvs def
  /lpo pol length def /lco cor length def /lst sty length def /fon 71 string def
  fon 0 pol p@t lco lst add 0 ne
   {fon lpo (-) p@t fon lpo 1 add cor p@t fon lpo 1 add lco add sty p@t}{/lpo lpo 1 sub def} ifelse
  bavard{/err 100 string def err 0 fon 0 lpo lco lst 1 add add add g@t p@t} if
  lst 0 ne{sty 0 1 g@t (O) eq {mats 2 mats 3 get 0.25 mul put} if
           sty 0 1 g@t (I) eq {mats 2 mats 3 get 0.2  mul put} if} if
  fon 0 lpo lco lst 1 add add add g@t cvn FontDirectory exch known
    {/lfo lpo lco lst 1 add add add def bavard {err 50 (OK) p@t err counttomark 1 roll} if}
    {fon 0 lpo lco 1 add add g@t cvn FontDirectory exch known {true}{
      fon 0 lpo g@t cvn FontDirectory exch known {/cor () def /lco 0 def true}
      {/cor (Roman) def /lco 5 def fon 0 fon lpo 1 add cor p@t
       lpo lco 1 add add g@t cvn FontDirectory exch known
      {true}{/cor () def /lco 0 def false} ifelse } ifelse } ifelse
      {fon lpo (-) p@t fon lpo 1 add cor p@t fon lpo 1 add lco add sty p@t
        lst 0 ne {fon 0 lpo lco lst 1 add add add g@t cvn FontDirectory exch known}{false}ifelse
        {/lfo lpo lco lst 1 add add add def
          bavard {err 50 (--> ) p@t err 54 fon 0 lfo g@t p@t err counttomark 1 roll } if }
        {lco 0 ne {/lfo lpo lco 1 add add def}{/lfo lpo def} ifelse /mat mats def
          bavard {err 50 (--> ) p@t err 54 fon 0 lfo g@t p@t
                  lst 0 ne{err 54 lfo add ( /penche/) p@t} if err counttomark 1 roll} if } ifelse }
      {dup dup /fon exch (m) eq {fontm0}{fontp0}ifelse 71 string cvs def /lfo fon length def /mat mats def
         bavard {(m) eq {err 50 (--> fontm0 par defaut) p@t}{err 50 (--> fontp0 par defaut) p@t}ifelse
                lst 0 ne{err 71 ( /penche/) p@t} if err counttomark 1 roll}{pop} ifelse } ifelse
    } ifelse
    pop fon 0 lfo g@t cvn findfont mat makefont setfont newpath 0 0 moveto
    (abcdefghijklmnopqrstuvwxyz ABCDEFGHIJKLMNOPQRSTUVWXYZ 1234567890) true charpath flattenpath pathbbox
    4 1 roll exch pop exch sub exch 4 1 roll exch 1.0 mul exch div 3 1 roll 1.0 mul dup /tfont exch def exch div
    dup mat 2 mat 2 get 4 -1 roll mul put mat 3 mat 3 get 4 -1 roll mul put mat 0 mat 0 get 4 -1 roll mul put
    fon 0 lfo g@t cvn findfont mat makefont setfont
} bind def
