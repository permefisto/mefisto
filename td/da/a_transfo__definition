deftms ~>TRANSFO>>DEFINITION 'definition of a TRANSFORMATION'
variable muet DATE 'date of creation of the TMS'   reel2  ;
variable muet NUTD 'number of the descriptor array TD' entier ;
variable NUTYTR 'type of transformation'    entier
      ( 1  : 'identity R3 -> R3'
      , 3  : 'isometry R3 -> R3'
      , 4  : 'projection in R3'
      , 6  : 'F:R3->R3 define by 3 functions (FX FY FZ)'
      , 7  : 'F:R3->R3 12 functions (Fi et [dFi/dxj])' ) ;
 cas NUTYTR
 3 : variable NUTYIS 'number of isometry type' entier
      ( 0: 'translation defined by a R3 vector'
      , 1: 'translation+rotation+dilatation defined by 2 points+7 reals'
      , 2: 'translation+rotation+dilatation defined by 4 images of 4 points' 
      , 3: 'translation+rotation defined by 3 images of 3 points' 
      , 4: 'symmetry plane defined by 3 points'
      , 5: 'symmetry line defined by 2 points'
      , 6: 'symmetry point'
      , 7: 'X Y Z dilatation' ) ;
  cas NUTYIS  
    0: tableau  TRAVEC(1..3) '3 components of the translation vector' reel ;
    1: variable NUP1AX 'name of point 1 of the rotation axis' ^~>POINT ;
       variable NUP2AX 'name of point 2 of the rotation axis' ^~>POINT ;
       variable ANGLE  'angle (degrees) of the rotation' reel ;
       variable TRANSX 'abscisse of the translation vector' reel ;
       variable TRANSY 'ordinate of the translation vector' reel ;
       variable TRANSZ 'cote     of the translation vector' reel ;
       variable DILATX 'coefficient of X-dilatation' reel ;
       variable DILATY 'coefficient of Y-dilatation' reel ;
       variable DILATZ 'coefficient of Z-dilatation' reel ;
    2: variable NUAVP1 'name of the point 1 before the isometry' ^~>POINT ;
       variable NUAVP2 'name of the point 2 before the isometry' ^~>POINT ;
       variable NUAVP3 'name of the point 3 before the isometry' ^~>POINT ;
       variable NUAVP4 'name of the point 4 before the isometry' ^~>POINT ;
       variable NUAPP1 'name of the point 1 after the isometry' ^~>POINT ;
       variable NUAPP2 'name of the point 2 after the isometry' ^~>POINT ;
       variable NUAPP3 'name of the point 3 after the isometry' ^~>POINT ;
       variable NUAPP4 'name of the point 4 after the isometry' ^~>POINT ; 
    3: variable NUP1AV 'name of the point 1 before the isometry' ^~>POINT ;
       variable NUP2AV 'name of the point 2 before the isometry' ^~>POINT ;
       variable NUP3AV 'name of the point 3 before the isometry' ^~>POINT ;
       variable NUP1AP 'name of the point 1 after the isometry' ^~>POINT ;
       variable NUP2AP 'name of the point 2 after the isometry' ^~>POINT ;
       variable NUP3AP 'name of the point 3 after the isometry' ^~>POINT ;
    4: variable NUP1PL 'name of the point 1 of the symmetry plane' ^~>POINT ;
       variable NUP2PL 'name of the point 2 of the symmetry plane' ^~>POINT ;
       variable NUP3PL 'name of the point 3 of the symmetry plane' ^~>POINT ;
    5: variable NUP1DR 'name of the point 1 of the symmetry line' ^~>POINT ;
       variable NUP2DR 'name of the point 2 of the symmetry line' ^~>POINT ;
    6: variable NUP1SY 'name of the symmetry point' ^~>POINT ;
    7: variable DILA7X 'coefficient of X-dilatation' reel ;
       variable DILA7Y 'coefficient of Y-dilatation' reel ;
       variable DILA7Z 'coefficient of Z-dilatation' reel ;
  fincas ;
 4 : variable NUFONC 'name of the function F(u,v,w)=0'  ^~>FONCTION ;
     variable NUTYPR 
      'number type of the projection on the surface F(u,v,w)=0'  entier
      ( 1 : '+oX projection'   
      ,-1 : '-oX projection'
      , 2 : '+oY projection' 
      ,-2 : '-oY projection'
      , 3 : '+oZ projection' 
      ,-3 : '-oZ projection'
      , 4 : 'projection from a centre and the point to be projected' 
      , 5 : 'orthogonal projection from a plane defined by 3 points'
      , 6 : 'orthogonal projection from a line defined by 2 points' ) ;
  cas NUTYPR
     4 : variable NUPTCP 'name of the point centre of projection'  ^~>POINT ;
     5 : variable NUPLP1 'name of the point 1 of the plane' ^~>POINT ;
         variable NUPLP2 'name of the point 2 of the plane' ^~>POINT ;
         variable NUPLP3 'name of the point 3 of the plane' ^~>POINT ; 
     6 : variable NUDRP1 'name of the point 1 of the line' ^~>POINT ;
         variable NUDRP2 'name of the point 2 of the line' ^~>POINT ;
  fincas ;
 6 : variable NUFONX 'name function ABSCISSE X=F1(u,v,w)' ^~>FONCTION ;
     variable NUFONY 'name function ORDINATE Y=F2(u,v,w)' ^~>FONCTION ;
     variable NUFONZ 'name function COTE     Z=F3(u,v,w)' ^~>FONCTION ;
 7 : variable NUFONX 'name function ABSCISSE X=F1(u,v,w)' ^~>FONCTION ;
     variable NUFONY 'name function ORDINATE Y=F2(u,v,w)' ^~>FONCTION ;
     variable NUFONZ 'name function COTE     Z=F3(u,v,w)' ^~>FONCTION ;
     variable NUDF1U 'name function dF1/du(u,v,w)' ^~>FONCTION ;
     variable NUDF1V 'name function dF1/dv(u,v,w)' ^~>FONCTION ;
     variable NUDF1W 'name function dF1/dw(u,v,w)' ^~>FONCTION ;
     variable NUDF2U 'name function dF2/du(u,v,w)' ^~>FONCTION ;
     variable NUDF2V 'name function dF2/dv(u,v,w)' ^~>FONCTION ;
     variable NUDF2W 'name function dF2/dw(u,v,w)' ^~>FONCTION ;
     variable NUDF3U 'name function dF3/du(u,v,w)' ^~>FONCTION ;
     variable NUDF3V 'name function dF3/dv(u,v,w)' ^~>FONCTION ;
     variable NUDF3W 'name function dF3/dw(u,v,w)' ^~>FONCTION ;
fincas ;
fintms ;
