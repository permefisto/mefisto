deftms ~>>>INTERFACE 'nodes of an interface between several materials'
variable muet DATE 'date of creation of the TMS' reel2  ;
variable muet NUTD 'number of the descriptor array TD' entier ; 
variable NBNOIN 'number of nodes of the interface'   entier ;
variable MXOBNO 'max number of materials of a node' entier ;
variable LONUNO 'number of integers of the array NUNOOB' entier ;
tableau  NBOBNO(1..NBNOIN) 'number of materials of each node' entier ;
tableau  NUNOOB(1..LONUNO) 'for each node the type number (PLSV),
number in this type and node number in the material'  entier ;
tableau  COOR(1..3,1..NBNOIN)
        'coordinates of each node of the interface' reel ;
fintms ;
