variable muet DATE 'date of creation of the TMS'   reel2  ;
variable muet NUTD 'number of the descriptor array TD' entier ; 
variable DEGXQB 'degree of first parameter of polynomials' entier ;   
variable DEGYQB 'degree of second parameter of polynomials' entier ;
variable NBCOQB 'number of components of the BSPLINE (3 or 4)' entier ;
variable NBIXQB 'number of intervals of first parameter' entier ;
variable NBIYQB 'nombre d''intervals of second parameter' entier ;
tableau  PARXQB(0..NBIXQB) 'values of first parameter' reel;
tableau  PARYQB(0..NBIYQB) 'values of second parameter' reel;
tableau  SPLIQB(0..DEGXQB,0..DEGYQB,1..NBIXQB,1..NBIYQB,1..NBCOQB)
         'coefficients of polynomials' reel ;
fintms ;
