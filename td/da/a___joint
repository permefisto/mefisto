deftms ~>>>JOINT 'common lines to several objects'
variable muet DATE 'date of creation of the TMS' reel2  ;
variable muet NUTD 'number of the descriptor array TD' entier ; 
variable NBJOIN 'nombre of joints'   entier ;
variable MXNOJO 'max number of nodes in a same joint' entier ;
tableau  NBOBJE(1..NBJOIN,1..4) 
'for each joint the types and numbers of associated PLSV' entier ;
tableau  NBNUJO(1..NBJOIN,1..2) 
'for each joint the number of associated nodes' entier ;
tableau  NUNOJO(1..NBJOIN,1..2,1..MXNOJO)                                          
'for each joint the number of each associated nodes' entier ;
tableau  COOR(1..NBJOIN,1..2,1..MXNOJO,1..3)
'coordinates of each node of the joint' reel ;
fintms ;
