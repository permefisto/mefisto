 'NOM des lignes definissant les 3 points de chaque surface plane des tranches'
          ^~>LIGNE ;
      2 : variable NBTRCS 'Nombre de tranches du volume final' entier ;
          variable ZMAXCS 'cote maximale Z a decouper en tranches' reel ;
      3 : variable NBTRCS 'Nombre de tranches du volume final' entier ;
          tableau  ZCTRCS(1..NBTRCS)
                  'cote (z>0) de chaque surface des tranches'  reel   ;
      4 : variable NBTRCS 'Nombre de tranches du volume final' entier ;
          tableau  TRCOCS(1..3)
                  'vecteur constant de translation des tranches' reel ; 
      5 : variable NBTRCS 'Nombre de tranches du volume final' entier ;
          tableau  TRVACS(1..3,1..NBTRCS)
                  'vecteur de translation de chacune des tranches' reel ;
