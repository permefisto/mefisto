deftms ~>>>NSEF 'Numero des SOMMETS TG des EF d''un PLSV avant interpolation'
variable muet DATE 'date de creation du tableau'   reel2  ;
variable muet NUTD 'Numero du tableau descripteur' entier ;
variable NUTYOB 'Type du PLSV' entier
( 1 : 'point' , 2 : 'ligne' , 3 : 'surface' , 4 : 'volume' )  ;
variable NUTFMA 'Ligne ou Surface Fermee ou NON-Ferme (P et V sont inconnus)'
        entier  
( -1 : 'inconnu' , 0 : 'non-ferme' , 1 : 'ligne ou surface fermee' ) ;
variable NBSOEF 'Nombre de sommets par EF' entier
( 1 : 'sommet' , 2 : 'arete' , 4 : 'face' , 8 : 'cube' , 64 : '6cubes' ) ;
variable NBTGEF 'Nombre de tangentes par EF' entier
( 0 : '0 tg par EF' , 1 : '1 tg par sommet' , 2 : '2 tg par arete' ,
  8 : '8 tg par face' ,  24 : '24 tg par cube' )  ;
variable NBEFOB 'Nombre des EF du PLSV' entier ;
variable NBEFTG 'Nombre des EF avec TG' entier ; 
variable NBEFAP 'Nombre des EF avec POINTEUR sur EF a TG' entier ;  
variable NUTYMA 'Numero de type du maillage' entier
( 0 : 'non structure' ,
  1 : 'noeudsommet structure' , 2 : 'segment    structure' ,
  3 : 'triangle    structure' , 4 : 'quadrangle structure' ,
  5 : 'tetraedre   structure' , 6 : 'pentaedre  structure' , 
  7 : 'hexaedre    structure' , 8 : '6-cube     structure' ) ;
cas NUTYMA
 0: tableau  NUSOEF(1..NBSOEF,1..NBEFOB)
    'Numero des sommets des EF du PLSV'  entier ; 
 1: variable NBARNS 'Nombre de noeudsommets' entier ;
 2: variable NBARSE 'Nombre d''aretes du segment structure' entier ;    
 3: variable NBARTR 'Nombre d''aretes de chaque cote du triangle structure'
                     entier ;    
 4: variable NBARXQ 'Nombre d''aretes du cote 1 et 3 du quadrangle structure'
                     entier ;    
    variable NBARYQ 'Nombre d''aretes du cote 2 et 4 du quadrangle structure'
                     entier ;  
 5: variable NBARTE 'Nombre d''aretes de chaque cote du tetraedre structure'
                     entier ;    
 6: variable NBARTP 'Nombre d''aretes des cotes des triangles du pentaedre'
                     entier ;    
    variable NBARZP 'Nombre d''aretes des cotes restants du pentaedre structure'
                     entier ;
 7: variable NBARXH 'Nombre d''aretes des cotes X de l''hexaedre structure'
                     entier ;     
    variable NBARYH 'Nombre d''aretes des cotes Y de l''hexaedre structure'
                     entier ;           
    variable NBARZH 'Nombre d''aretes des cotes Z de l''hexaedre structure'
                     entier ; 
 8: variable NANCUB 'Nombre d''aretes dans une direction du 6-cube' entier ;
    variable NDNCUB 'Dimension du 6-cube => 6' entier;  
fincas ;
tableau LPEFTG(1..NBEFAP) 'Numero>0 de l''EF a TG sinon 0' entier ;
tableau NGEFTG(1..NBEFTG) 'Numero geometrique de l''EF a TG' entier
( 0 : 'C1 degre 3' ,
  1 : 'CERCLE' ,     2 : 'ELLIPSE' ,      3 : 'COURBE B-SPLINE' ,
 11 : 'SPHERE' ,    12 : 'ELLIPSOIDE' ,  13 : 'CYLINDRE' ,  14 : 'CONE' ,
 15 : 'TORE'   ,    16 : 'TRANSFINI'  ,  17 : 'SURFACE B-SPLINE') ;
tableau NUTGEF(1..NBTGEF,1..NBEFTG) '+-No des TANGENTES de l''EF a TG' entier ;
fintms ;
