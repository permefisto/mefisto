     tableau  NUCOFO(1..NBCOFO) 'No des composantes de la Force' entier ;
     variable NFFORC 'Nom de la fonction FORCE'  ^~>FONCTION ;
 1 : variable NBCOF0 'Nombre de composantes de la Force' entier ; 
     tableau  NUCOF0(1..NBCOF0) 'No des composantes de la Force' entier ;
     tableau  FORCE(1..NBCOF0) 'Valeur de ces composantes de la Force' reel ;
