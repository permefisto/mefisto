     variable NBAYQB 'nombre d''aretes en V' entier ;
     variable RAGXQB 'raison geometrique d''espacement en U des sommets' reel ; 
     variable RAGYQB 'raison geometrique d''espacement en V des sommets' reel ; 
     variable LDEXSB 'degre en U des polynomes' entier ;
     variable LDEYSB 'degre en V des polynomes' entier ; 
     variable NBPIEX 'nombre de points d''interpolation en U' entier;
     variable NBPIEY 'nombre de points d''interpolation en V' entier;
