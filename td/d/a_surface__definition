      variable NUP1AS 'nom du 1-er  point de l''axe' ^~>POINT ; 
      variable NUP2AS 'nom du 2-eme point de l''axe' ^~>POINT ;
      variable NBANAS 'nombre d''angles de rotation autour de l''axe' entier ;
      variable NTYPAS 'type des angles de rotation'  entier
                      ( 0 : 'angles constants' , 1 : 'angles variables' ) ;
      cas NTYPAS 
      0 : variable ANMXAS 'angle (en degres) total des rotations' reel ;
      1 : tableau  ANGLAS(1..NBANAS) 'angles relatifs en degres des rotations'
          reel ;
      fincas ; 
