 cas NUTYSU
  1: tableau  NU4COT(1..4)  'nom des 4 lignes des 4 cotes' ^~>LIGNE ; 
     variable LAGHER 'type du maillage' entier 
    (  1: 'maillage regulier'
    ,  2: 'maillage irregulier' );
