 14 : variable NULICL 'nom de la ligne initiale des tranches'  ^~>LIGNE ;
      variable NUTYCL 'numero du type de definition des tranches' entier 
( 0: '3 points par surface definissent les transformations' ,
  1: '3 lignes definissent les transformations de la ligne' ,
  2: 'lignes translatees d''une cote z>0 constante (empilement)' ,
  3: 'lignes translatees d''une cote z>0 precisee pour chaque ligne' ,
  4: 'le  vecteur  translation  (x y z) valable pour toutes les tranches' ,
  5: 'les vecteurs translations (x y z) definis un par tranche' ,
  6: '3 fonctions X Y Z(no_tranche,x,y,z) transforment la ligne initiale' ) ;
      cas NUTYCL
      0 : variable NBTRCL 'nombre de tranches de la surface finale'  entier ;
          tableau  NPTRCL(1..3,0..NBTRCL)
         'nom des 3 points definissant chaque surface plane des tranches'
          ^~>POINT ; 
      1 : tableau  NLTRCL(1..3)
 'nom des lignes definissant les 3 points de chaque surface plane des tranches'
          ^~>LIGNE ;
      2 : variable NBTRCL 'nombre de tranches de la surface finale' entier ;
          variable ZMAXCL 'cote maximale Z a decouper en tranches' reel ;
      3 : variable NBTRCL 'nombre de tranches de la surface finale' entier ;
          tableau  ZCTRCL(1..NBTRCL)
                  'cote absolue (z>0) de chaque ligne des tranches'  reel  ;
      4 : variable NBTRCL 'nombre de tranches de la surface finale' entier ;
          tableau  TRCOCL(1..3)
                 'X Y Z du vecteur constant de translation des tranches' reel ;
      5 : variable NBTRCL 'nombre de tranches de la surface finale' entier ;
          tableau  TRVACL(1..3,1..NBTRCL)
               'X Y Z du vecteur de translation des tranches / precedente' reel ;
      6 : variable NBTRCL 'nombre de tranches de la surface finale' entier ;
      variable FONXCL 'fonction abscisse X(no_tranche,x0,y0,z0)' ^~>FONCTION ;
      variable FONYCL 'fonction ordonnee Y(no_tranche,x0,y0,z0)' ^~>FONCTION ;
      variable FONZCL 'fonction cote     Z(no_tranche,x0,y0,z0)' ^~>FONCTION ;
      fincas ;
