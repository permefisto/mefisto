deftms ~>>>CONDUCTIVITE  'Conductivite de l''objet'
variable muet DATE   'date de creation du tableau'   reel2  ;
variable muet NUTD   'numero du tableau descripteur' entier ;  
variable      LTCOND 'Type de Conductivite' entier 
( 1 : 'Materiau 3D homogene isotrope constant' ,
  2 : 'Materiau AXISYMETRIQUE homogene ISOTROPE constant' ,
  3 : 'Materiau 1D ou 2D homogene ISOTROPE constant' ,
 10 : 'Tenseur de constante Conductivite ANISOTROPE C11 C12 C22...' ,
 -1 : 'Fonction Conductivite   ISOTROPE' ,
 -2 : 'Fonction Conductivite ANISOTROPE' ,
  0 : 'Supprimer la Conductivite actuelle' ) ;
cas LTCOND
1..3 : variable CONDUC 'Constante conductivite du materiau'  reel   ;
10: variable NVCOND
  'NOMBRE de coefficients constants du tenseur Conductivite C11 C12 C22...'
     entier ;
    tableau  TECOND(1..NVCOND) 
   'constants COEFFICIENTS C11,C21,C22,... du tenseur Conductivite' reel ;  
-1 : variable NFCOND 'NOM FONCTION Conductivite ISOTROPE'   ^~>FONCTION ;
-2 : variable NVCOAN
    'NOMBRE de coefficients du tenseur de Conductivite C11 C12 C22...'
     entier ;
     variable NFCOAN 'NOM FONCTION Conductivite ANISOTROPE' ^~>FONCTION ;
fincas ;   
fintms ;
