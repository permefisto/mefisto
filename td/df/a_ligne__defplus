, 13 : 'B-spline ouverte non uniforme polynomiale C?'
 13: variable NBARLI 'nombre d''aretes de la ligne B-spline' entier ;
     variable RAGEBL 'raison geometrique espacant les sommets' reel ;
     variable NDEGBL 'degre des polynomes de la B-spline' entier ;
     variable NBPCBL 'nombre de points de controle (>degre)' entier ;
     tableau  NUPLBO(1..NBPCBL) 'nom des points de controle'   ^~>POINT ;
     variable NBNOBO 'nombre de noeuds (nombre de points + degre + 1)' entier ;
     tableau  NOETBO(1..NBNOBO) 'toutes les valeurs des noeuds' reel ;


